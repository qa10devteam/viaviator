---
/**
 * /o-nas — strona „O nas" Via Viator (PL).
 *
 * Siedem sekcji:
 *  1. Hero          — close-up V logo, eyebrow konkretny (Patryk odbiera telefon).
 *  2. Po co jesteśmy — Mission, dlaczego firma powstała.
 *  3. Jak jeździmy  — 6 zasad operacyjnych Via Viator, numerowana lista.
 *  4. Zespół        — Patryk (face of brand) + drobna nota o współzałożeniu.
 *  5. Gdzie jeździmy — 4 województwa + 3 huby lotniskowe, prawa kolumna = inline SVG PL.
 *  6. Flota         — Trafic + Master jako karty, plus sprzęt eventowy poniżej.
 *  7. CTA           — „Zaplanuj z nami kurs/wycieczkę/wynajem" → /kontakt.
 *
 * SEO: seoMap.oNas + JSON-LD BreadcrumbList.
 * A11y: każda sekcja ma `aria-labelledby`, kontrast WCAG AA, mapa SVG ma `role="img"` + `aria-label`.
 *
 * Architektura zgodna z `przewozy-rodzinne.astro` (sekcje + tone alternation default↔elevated↔surface).
 * Wartości tekstowe pochodzą z `dict.about.*` — żadnych hardkodów.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Card from "@components/ui/Card.astro";
import Icon from "@components/ui/Icon.astro";
import SectionIndex from "@components/ui/SectionIndex.astro";
import Hero from "@components/sections/Hero.astro";
import CTASection from "@components/sections/CTASection.astro";
import PullQuote from "@components/sections/PullQuote.astro";
import AtlasPoludnia from "@components/sections/AtlasPoludnia.astro";
import { getDictionary } from "@i18n/index";
import { company } from "@data/company";
import { seoMap, buildCanonical, buildAlternates } from "@lib/seo";
import { breadcrumbForRoute } from "@lib/schema";

const locale = "pl" as const;
const dict = getDictionary(locale);
const seo = seoMap.oNas;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("oNas", locale, SITE);
const alternates = buildAlternates("oNas", SITE);

// JSON-LD: BreadcrumbList — Home → O nas.
const breadcrumbJsonLd = breadcrumbForRoute("oNas", locale, SITE);

// ─────────────────────────────────────────────────────────────────────────────
// Adapter danych z dict — typujemy opcjonalne pola, żeby strona zadziałała
// nawet jeśli słownik tymczasowo nie dostarczy `howWeWork`, `fleet.items`
// lub `team.body`. Gdy słownik je zawiera — używamy ich bezpośrednio.
// ─────────────────────────────────────────────────────────────────────────────

interface AboutRule {
  title: string;
  body: string;
}
interface AboutHowWeWork {
  title: string;
  body: string;
  rules: ReadonlyArray<AboutRule>;
}
interface AboutFleetItem {
  model: string;
  desc: string;
}

type AboutLike = {
  howWeWork?: AboutHowWeWork;
  team?: { body?: string };
  fleet?: { items?: ReadonlyArray<AboutFleetItem>; eventEquipment?: string };
};

const aboutExtra = dict.about as unknown as AboutLike;

// Tytuł i lead sekcji „Jak jeździmy". Fallback minimalny — agent dict
// zwykle dostarcza pełną treść (sześć reguł operacyjnych).
const howWeWork: AboutHowWeWork = aboutExtra.howWeWork ?? {
  title: "Jak jeździmy",
  body: "Sześć reguł operacyjnych. Tak samo dla transferu o czwartej rano i dla pielgrzymki w niedzielę.",
  rules: [],
};

// Pojazdy floty — dwie pozycje (Trafic + Master). Fallback opisowy
// utrzymuje sekcję widoczną, gdy słownik nie zawiera jeszcze `items`.
const fleetItems: ReadonlyArray<AboutFleetItem> =
  aboutExtra.fleet?.items ?? [
    {
      model: "Renault Trafic",
      desc: "Bus osobowy, 8 miejsc. Transfery, pielgrzymki, transport rodzinny.",
    },
    {
      model: "Renault Master",
      desc: "Osobowy lub cargo, 8 miejsc. Wynajem krótkoterminowy, przeprowadzki, sprzęt eventowy.",
    },
  ];

// Opis sprzętu eventowego jako paragraf pod gridem flotowym.
const fleetEventEquipment: string =
  aboutExtra.fleet?.eventEquipment ??
  "Plus sprzęt eventowy: namiot, maszyna do popcornu, maszyna do waty cukrowej. Jesienią 2026 dochodzą stoły i ławki biesiadne.";

// Krótkie wprowadzenie do sekcji zespołu.
const teamBody: string =
  aboutExtra.team?.body ??
  "Mała flota, znajome twarze, ten sam numer telefonu od dwóch lat.";

// Inicjały Patryka — placeholder zamiast portretu (klient nie udostępnił zdjęcia).
const patrykInitials = "PT";
---

<BaseLayout
  title={seo.titlePl}
  description={seo.descriptionPl}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={`${SITE}${seo.ogImage}`}
  jsonLd={breadcrumbJsonLd}
  bodyClass="page-about"
>
  {/* 1. HERO — close-up V logo, headline z dict.about.h1 */}
  <Hero
    eyebrow="Patryk Tomeczek odbiera telefon"
    headline={dict.about.h1}
    subhead={dict.about.intro}
    image="/images/brand-detail/brand-logo-close.jpg"
    imageAlt="Logo Via Viator na karoserii Renault Trafic — zbliżenie na literę V."
    align="left"
    tone="default"
    priority={true}
  />

  {/* 2. „Po co jesteśmy" — dlaczego firma powstała.
       SectionIndex N°02 + drop-cap na pierwszym (jedynym) paragrafie. */}
  <Section tone="elevated" ariaLabelledby="about-mission-title">
    <Container size="default">
      <div class="vv-about-mission vv-reveal drop-cap">
        <SectionIndex number={2} label="Po co jesteśmy" />
        <h2 id="about-mission-title" class="vv-about-section-title">
          {dict.about.mission.title}
        </h2>
        <p class="vv-about-mission__lead">{dict.about.mission.body}</p>
      </div>
    </Container>
  </Section>

  {/* 3. „Jak jeździmy" — 6 zasad operacyjnych Via Viator (cascade na regułach) */}
  <Section tone="default" ariaLabelledby="about-rules-title">
    <Container size="default">
      <header class="vv-about-section-head vv-reveal">
        <SectionIndex number={3} label="Jak jeździmy" />
        <h2 id="about-rules-title" class="vv-about-section-title">
          {howWeWork.title}
        </h2>
        <p class="vv-about-section-lead">{howWeWork.body}</p>
      </header>

      <ol class="vv-about-rules" role="list" data-reveal-cascade>
        {
          howWeWork.rules.map((rule, index) => (
            <li class="vv-reveal">
              <Card tone="default" class="vv-about-rule">
                <span class="vv-about-rule__number" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h3 class="vv-about-rule__title">{rule.title}</h3>
                <p class="vv-about-rule__body">{rule.body}</p>
              </Card>
            </li>
          ))
        }
      </ol>
    </Container>
  </Section>

  {/* 4. Zespół — Patryk + drobna nota o współzałożeniu + pull-quote */}
  <Section tone="surface" ariaLabelledby="about-team-title">
    <Container size="default">
      <header class="vv-about-section-head vv-reveal">
        <SectionIndex number={4} label="Zespół" />
        <h2 id="about-team-title" class="vv-about-section-title">
          {dict.about.team.title}
        </h2>
        <p class="vv-about-section-lead">{teamBody}</p>
      </header>

      <PullQuote
        quote="Mała flota, znajome twarze, ten sam numer telefonu od dwóch lat."
        attribution="Patryk Tomeczek"
      />

      <div class="vv-about-team vv-reveal">
        {/* Patryk — face of brand, avatar placeholder z inicjałami */}
        <Card tone="elevated" class="vv-about-team__card">
          <div class="vv-about-team__avatar" aria-hidden="true">
            <span class="vv-about-team__initials">{patrykInitials}</span>
          </div>
          <div class="vv-about-team__copy">
            <h3 class="vv-about-team__name">{dict.about.team.patrykName}</h3>
            <p class="vv-about-team__role">{dict.about.team.patrykRole}</p>
            <p class="vv-about-team__bio">{dict.about.team.patrykBio}</p>
          </div>
        </Card>

        {/* Nota o współzałożeniu — krótki paragraf bez tytułu */}
        <Card tone="outlined" class="vv-about-team__card vv-about-team__card--note">
          <p class="vv-about-team__note">{dict.about.team.foundingNote}</p>
        </Card>
      </div>
    </Container>
  </Section>

  {/* 5. „Gdzie jeździmy" — region + huby + huby lotniskowe + interaktywna mapa.
       Mapa (Wow#1 Atlas Południa, variant=compact) zastępuje prostą placeholder-mapę
       z v1.0 (PR M04). Listy województw/hubów zostają jako szybki tekstowy fallback
       dla SR / SEO indeksacji; AtlasPoludnia.astro daje wersję interaktywną. */}
  <Section tone="default" ariaLabelledby="about-region-title">
    <Container size="default">
      <header class="vv-about-section-head vv-reveal">
        <SectionIndex number={5} label="Gdzie jeździmy" />
        <h2 id="about-region-title" class="vv-about-section-title">
          {dict.about.region.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.region.body}</p>
      </header>

      <div class="vv-about-region vv-reveal">
        {/* Lewa kolumna — listy województw i hubów (szybki skan tekstowy) */}
        <div class="vv-about-region__lists">
          <div class="vv-about-region__group">
            <h3 class="vv-about-region__heading">Województwa</h3>
            <ul class="vv-about-region__list" role="list">
              {
                company.region.map((r) => (
                  <li>
                    <Icon name="map-pin" size={16} />
                    <span>{r}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="vv-about-region__group">
            <h3 class="vv-about-region__heading">Huby lotniskowe</h3>
            <ul class="vv-about-region__list" role="list">
              {
                company.hubs.map((h) => (
                  <li>
                    <Icon name="globe" size={16} />
                    <span>{h}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        {/* Prawa kolumna — interaktywna mapa Wow#1 (variant compact) */}
        <div class="vv-about-region__atlas">
          <AtlasPoludnia locale={locale} variant="compact" />
        </div>
      </div>
    </Container>
  </Section>

  {/* 6. Flota — grid kart pojazdów + sprzęt eventowy poniżej */}
  <Section tone="elevated" ariaLabelledby="about-fleet-title">
    <Container size="default">
      <header class="vv-about-section-head vv-reveal">
        <SectionIndex number={6} label="Flota" />
        <h2 id="about-fleet-title" class="vv-about-section-title">
          {dict.about.fleet.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.fleet.body}</p>
      </header>

      <ul class="vv-about-fleet__grid" role="list" data-reveal-cascade>
        {
          fleetItems.map((vehicle) => (
            <li class="vv-reveal">
              <Card tone="default" class="vv-about-fleet__card">
                <h3 class="vv-about-fleet__model">{vehicle.model}</h3>
                <p class="vv-about-fleet__desc">{vehicle.desc}</p>
              </Card>
            </li>
          ))
        }
      </ul>

      <p class="vv-about-fleet__event-note vv-reveal">{fleetEventEquipment}</p>
    </Container>
  </Section>

  {/* 7. CTA finalna — do /kontakt z mini-presetem */}
  <CTASection
    tone="brand"
    title="Zaplanuj z nami kurs, wycieczkę lub wynajem"
    body="Krótki brief: skąd, dokąd, kiedy, ile osób. Odpiszemy najszybciej, jak nasza obietnica pozwala."
    primaryCta={{
      label: dict.cta.sendBrief,
      href: "/kontakt",
      ariaLabel: "Przejdź do formularza kontaktowego",
    }}
    secondaryCta={{
      label: `Zadzwoń: ${company.phoneDisplay}`,
      href: company.phoneHref,
      ariaLabel: `Zadzwoń: ${company.phoneDisplay}`,
    }}
    align="center"
  />
</BaseLayout>

<style>
  /* ── Wspólne nagłówki sekcji ───────────────────────────────────────── */
  .vv-about-section-head {
    margin: 0 0 var(--vv-space-10) 0;
    max-width: 64ch;
  }

  .vv-about-section-title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 3.5vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-3) 0;
    text-wrap: balance;
  }

  .vv-about-section-lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* ── Mission ──────────────────────────────────────────────────────── */
  .vv-about-mission {
    max-width: 65ch;
  }

  .vv-about-mission__lead {
    margin: 0;
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
    text-wrap: pretty;
  }

  /* ── 6 zasad operacyjnych ─────────────────────────────────────────── */
  .vv-about-rules {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-6);
  }

  @media (min-width: 768px) {
    .vv-about-rules {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .vv-about-rules {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .vv-about-rule {
    height: 100%;
  }

  .vv-about-rule__number {
    display: block;
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-extrabold);
    color: var(--vv-color-brand-red-700);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0 0 var(--vv-space-3) 0;
  }

  .vv-about-rule__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-tight);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-2) 0;
  }

  .vv-about-rule__body {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-normal);
    margin: 0;
  }

  /* ── Zespół ───────────────────────────────────────────────────────── */
  .vv-about-team {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-about-team {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }

  .vv-about-team__card {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-5);
  }

  @media (min-width: 640px) {
    .vv-about-team__card:not(.vv-about-team__card--note) {
      flex-direction: row;
      align-items: center;
    }
  }

  .vv-about-team__card--note {
    justify-content: center;
  }

  .vv-about-team__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    border-radius: 50%;
    background: linear-gradient(
      135deg,
      var(--vv-color-brand-red) 0%,
      var(--vv-color-brand-red-700) 100%
    );
    box-shadow: var(--vv-shadow-md);
  }

  .vv-about-team__initials {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-3xl);
    font-weight: var(--vv-typography-font-weight-extrabold);
    color: var(--vv-color-brand-white);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
  }

  .vv-about-team__copy {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-2);
  }

  .vv-about-team__name {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-about-team__role {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--vv-typography-letter-spacing-wider);
    color: var(--vv-color-brand-red-700);
    margin: 0;
  }

  .vv-about-team__bio {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
  }

  .vv-about-team__note {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    font-style: italic;
  }

  /* ── Region ───────────────────────────────────────────────────────── */
  .vv-about-region {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-8);
  }

  @media (min-width: 1024px) {
    .vv-about-region {
      grid-template-columns: 1fr 1fr;
      gap: var(--vv-space-12);
      align-items: start;
    }
  }

  .vv-about-region__lists {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-6);
  }

  .vv-about-region__group {
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
    padding: var(--vv-space-6);
  }

  .vv-about-region__heading {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-4) 0;
  }

  .vv-about-region__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--vv-space-3);
  }

  .vv-about-region__list li {
    display: inline-flex;
    align-items: center;
    gap: var(--vv-space-2);
    padding: var(--vv-space-2) var(--vv-space-4);
    background-color: var(--vv-color-bg-surface);
    border-radius: var(--vv-radius-full);
    font-size: var(--vv-typography-font-size-sm);
    font-weight: var(--vv-typography-font-weight-medium);
    color: var(--vv-color-fg-primary);
  }

  .vv-about-region__list li :global(.vv-icon) {
    color: var(--vv-color-brand-red-700);
    flex-shrink: 0;
  }

  /* Wrapper dla AtlasPoludnia (variant=compact) embedded w /o-nas.
     Komponent dostarcza własne ramki/padding — tutaj tylko utrzymujemy
     spójność grid-column z lewą kolumną. */
  .vv-about-region__atlas {
    min-width: 0;
  }

  /* ── Flota ────────────────────────────────────────────────────────── */
  .vv-about-fleet__grid {
    list-style: none;
    margin: 0 0 var(--vv-space-8) 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-about-fleet__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .vv-about-fleet__card {
    height: 100%;
  }

  .vv-about-fleet__model {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-2) 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-about-fleet__desc {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
  }

  .vv-about-fleet__event-note {
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-left: 4px solid var(--vv-color-brand-red);
    border-radius: var(--vv-radius-md);
    padding: var(--vv-space-5) var(--vv-space-6);
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
    margin: 0;
  }
</style>
</content>
</invoke>