---
/**
 * /en/events — P6 Event gear (EN mirror).
 *
 * Mirrors /imprezy — explicit transparency about a young, growing offer
 * (3 items today, more in autumn 2026). Client asked for this honesty.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";
import Icon from "@components/ui/Icon.astro";
import Hero from "@components/sections/Hero.astro";
import FeatureGrid from "@components/sections/FeatureGrid.astro";
import FAQAccordion from "@components/sections/FAQAccordion.astro";
import CTASection from "@components/sections/CTASection.astro";
import { getDictionary } from "@i18n/index";
import {
  buildCanonical,
  buildAlternates,
  seoMap,
} from "@lib/seo";
import {
  serviceForSegment,
  breadcrumbForRoute,
  faqSchema,
} from "@lib/schema";
import { company } from "@data/company";

const locale = "en" as const;
const dict = getDictionary(locale);
const seg = dict.segments.eventy;
const seo = seoMap.eventy;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("eventy", locale, SITE);
const alternates = buildAlternates("eventy", SITE);

const phoneHref = company.phoneHref;
const askForOfferHref = "/en/contact?segment=eventy";

const equipmentToday = [
  {
    icon: "tent" as const,
    title: "Event tent",
    body:
      "Size matched to guest count (30 guests → 5×10 m, 50 guests → 6×12 m). Setup included. Delivered by our own Master cargo van — to a yard, a parish square, a plot of land.",
  },
  {
    icon: "sparkles" as const,
    title: "Popcorn machine",
    body:
      "Enough for a group of 50–80. Standard 230 V socket, walk-through on handover. Sugar and corn on your side or in a bundle — your call in the brief.",
  },
  {
    icon: "sparkles" as const,
    title: "Cotton candy machine",
    body:
      "50–80 guests with adequate sugar supply (1 kg bag ≈ 40 portions). We'll demo on site — it isn't rocket science, but there are tricks.",
  },
];

const eventTypes = [
  {
    icon: "church" as const,
    title: "Parish fairs",
    body:
      "Church square, tables for volunteers, popcorn for kids after Mass. We work with parish organisers across Silesia and Opole.",
  },
  {
    icon: "sparkles" as const,
    title: "Harvest fairs",
    body:
      "Tent for the mayor and the band, popcorn and cotton candy stalls for families. Invoice to the municipality, order details captured in the brief.",
  },
  {
    icon: "briefcase" as const,
    title: "Company events",
    body:
      "Team picnic, employee family day, new warehouse opening. VAT invoice, gear for the whole weekend, Friday setup — Monday pickup.",
  },
  {
    icon: "users" as const,
    title: "Home birthdays",
    body:
      "Garden, patio, country plot. Cotton candy for the kids, tent in case of rain. Delivery within 100 km of our base.",
  },
  {
    icon: "candle" as const,
    title: "Christenings and jubilees",
    body:
      "From church to home — a garden tent instead of a restaurant, popcorn and cotton candy as a surprise. Weekend rate (Fri 4 pm → Sun 8 pm).",
  },
  {
    icon: "sparkles" as const,
    title: "School events",
    body:
      "Children's day, end of year, family fair. Invoice to the parents' council or the school. Delivery within 100 km, further — by arrangement.",
  },
];

const advantages = [
  {
    icon: "shield-check" as const,
    title: "One contract",
    body:
      "Tent, popcorn, cotton candy, delivery, setup — all in one document. No coordinating three subcontractors the day before.",
  },
  {
    icon: "truck" as const,
    title: "One delivery",
    body:
      "All gear arrives in one Master run. No „popcorn driver stuck in traffic, tent driver hasn't left yet”.",
  },
  {
    icon: "briefcase" as const,
    title: "One invoice",
    body:
      "23% VAT invoice for a company, municipality, parish or a named receipt for an individual. One line in your books, not three.",
  },
  {
    icon: "phone" as const,
    title: "One number",
    body:
      `The emergency number is ${company.phoneDisplay} — Patryk picks up, or someone Patryk knows by name. No call centre, no „I'll pass it on”.`,
  },
];

const serviceJsonLd = serviceForSegment("eventy", locale, SITE);
const breadcrumbJsonLd = breadcrumbForRoute("eventy", locale, SITE);
const faqJsonLd = faqSchema([...seg.faq.items]);
---

<BaseLayout
  title={seo.titleEn}
  description={seo.descriptionEn}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={seo.ogImage}
  jsonLd={[serviceJsonLd, breadcrumbJsonLd, faqJsonLd]}
  bodyClass="page-segment page-eventy"
>
  {/* 1. HERO */}
  <Hero
    eyebrow={seg.name}
    headline={seg.heroHeadline}
    subhead="Three items today, more arriving in autumn 2026. We tell you straight what we have and what we don't — so you don't plan an event around promises."
    image="/images/services/service-events-tile.jpg"
    imageAlt="Family fair with an event tent and a popcorn machine."
    primaryCta={{
      label: "Ask about event offer",
      href: askForOfferHref,
      ariaLabel: "Ask about event offer — contact form",
    }}
    secondaryCta={{
      label: `Call: ${company.phoneDisplay}`,
      href: phoneHref,
      ariaLabel: `Call: ${company.phoneDisplay}`,
    }}
    microcopy="Same-day quote during business hours. Peak season May–September — book 3–4 weeks ahead."
  />

  {/* Time-to-quote bar */}
  <Section tone="surface" tight ariaLabel="Reply time and phone">
    <Container size="default">
      <div class="vv-eventy-meta">
        <Badge tone="brand">
          <Icon name="clock" size={14} />
          <span>24 hours — same-day quote during business hours</span>
        </Badge>
        <Badge tone="neutral">
          <Icon name="phone" size={14} />
          <span>{company.phoneDisplay}</span>
        </Badge>
      </div>
    </Container>
  </Section>

  {/* 2. WHAT WE HAVE TODAY */}
  <Section tone="default" ariaLabelledby="eventy-today-title">
    <Container size="default">
      <header class="vv-eventy-section-head">
        <p class="vv-eventy-eyebrow">As of today</p>
        <h2 id="eventy-today-title" class="vv-eventy-section-title">
          What we have today
        </h2>
        <p class="vv-eventy-section-lead">
          Three items that we deliver, set up and walk you through. All
          serviced, inspected before the season, transported in our own Master.
        </p>
      </header>

      <ul class="vv-eventy-equipment" role="list">
        {equipmentToday.map((item) => (
          <li>
            <Card tone="default" class="vv-eventy-equipment__card">
              <span class="vv-eventy-equipment__icon" aria-hidden="true">
                <Icon name={item.icon} size={28} />
              </span>
              <h3 class="vv-eventy-equipment__title">{item.title}</h3>
              <p class="vv-eventy-equipment__body">{item.body}</p>
            </Card>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  {/* 3. AUTUMN 2026 ROADMAP */}
  <Section tone="default" ariaLabelledby="eventy-roadmap-title">
    <Container size="default">
      <Card tone="brand" class="vv-eventy-roadmap">
        <div class="vv-eventy-roadmap__head">
          <Badge tone="brand">Roadmap · autumn 2026</Badge>
          <h2 id="eventy-roadmap-title" class="vv-eventy-roadmap__title">
            What we're preparing for autumn 2026
          </h2>
        </div>
        <ul class="vv-eventy-roadmap__list" role="list">
          <li>
            <Icon name="check" size={18} />
            <span><strong>Banquet tables</strong> — set of 10, foldable, transported in the Master.</span>
          </li>
          <li>
            <Icon name="check" size={18} />
            <span><strong>Banquet benches</strong> — set of 20, matched to the tables.</span>
          </li>
        </ul>
        <p class="vv-eventy-roadmap__note">
          We grow the event kit deliberately — we buy what we'd buy for our
          own events too. If you're planning a wedding or a harvest fair
          <strong> after September 2026</strong> — get in touch early, we'll
          tell you what we'll already have for your date and what's still
          coming.
        </p>
      </Card>
    </Container>
  </Section>

  {/* 4. EVENT TYPES */}
  <Section tone="elevated" ariaLabelledby="eventy-types-title">
    <Container size="default">
      <header class="vv-eventy-section-head">
        <p class="vv-eventy-eyebrow">Contexts</p>
        <h2 id="eventy-types-title" class="vv-eventy-section-title">
          For which events
        </h2>
        <p class="vv-eventy-section-lead">
          Six event types our gear fits best. If you're organising something
          not on this list — describe it in the brief, we'll assess honestly.
        </p>
      </header>
      <FeatureGrid items={eventTypes} columns={3} tone="default" />
    </Container>
  </Section>

  {/* 5. WHY US */}
  <Section tone="default" ariaLabelledby="eventy-advantages-title">
    <Container size="default">
      <header class="vv-eventy-section-head">
        <p class="vv-eventy-eyebrow">Why us</p>
        <h2 id="eventy-advantages-title" class="vv-eventy-section-title">
          Why us — instead of three separate suppliers
        </h2>
        <p class="vv-eventy-section-lead">
          Event stress comes from coordination. Three subcontractors, three
          contracts, three phones, three invoices. With us — one chain.
        </p>
      </header>
      <ul class="vv-eventy-advantages" role="list">
        {advantages.map((adv) => (
          <li class="vv-eventy-advantage">
            <span class="vv-eventy-advantage__icon" aria-hidden="true">
              <Icon name={adv.icon} size={22} />
            </span>
            <div class="vv-eventy-advantage__copy">
              <h3 class="vv-eventy-advantage__title">{adv.title}</h3>
              <p class="vv-eventy-advantage__body">{adv.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  {/* 6. DECISION CRITERIA */}
  <Section tone="surface" ariaLabelledby="eventy-decision-title">
    <Container size="default">
      <header class="vv-eventy-section-head">
        <h2 id="eventy-decision-title" class="vv-eventy-section-title">
          {seg.decisionList.title}
        </h2>
        <p class="vv-eventy-section-lead">{seg.decisionList.body}</p>
      </header>
      <ul class="vv-eventy-decision" role="list">
        {seg.decisionList.items.map((item) => (
          <li class="vv-eventy-decision__item">
            <p class="vv-eventy-decision__q">{item.q}</p>
            <p class="vv-eventy-decision__a">{item.a}</p>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  {/* 7. FAQ */}
  <Section tone="default" ariaLabelledby="eventy-faq-title">
    <Container size="default">
      <header class="vv-eventy-section-head">
        <h2 id="eventy-faq-title" class="vv-eventy-section-title">
          {seg.faq.title}
        </h2>
      </header>
      <FAQAccordion items={[...seg.faq.items]} defaultOpenFirst={true} />
    </Container>
  </Section>

  {/* 8. CTA brand */}
  <CTASection
    title="Ask about the event offer"
    body="Tell us the date, location, guest count, gear list — we'll send back a quote the same day. Peak season May–September — book 3–4 weeks ahead."
    primaryCta={{
      label: "Ask about event offer",
      href: askForOfferHref,
      ariaLabel: "Ask about event offer — contact form",
    }}
    secondaryCta={{
      label: `Call: ${company.phoneDisplay}`,
      href: phoneHref,
      ariaLabel: `Call: ${company.phoneDisplay}`,
    }}
    tone="brand"
  />
</BaseLayout>

<style>
  .vv-eventy-section-head {
    margin: 0 0 var(--vv-space-10) 0;
    max-width: 64ch;
  }

  .vv-eventy-eyebrow {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-xs);
    letter-spacing: var(--vv-typography-letter-spacing-wider);
    text-transform: uppercase;
    color: var(--vv-color-brand-red-700);
    margin: 0 0 var(--vv-space-3) 0;
  }

  .vv-eventy-section-title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 3.5vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-3) 0;
    text-wrap: balance;
  }

  .vv-eventy-section-lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  .vv-eventy-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--vv-space-3);
    align-items: center;
  }

  .vv-eventy-equipment {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 640px) {
    .vv-eventy-equipment {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .vv-eventy-equipment {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .vv-eventy-equipment__card {
    height: 100%;
  }

  .vv-eventy-equipment__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background-color: var(--vv-color-brand-red-50);
    color: var(--vv-color-brand-red-700);
    border-radius: var(--vv-radius-lg);
  }

  .vv-eventy-equipment__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-eventy-equipment__body {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
  }

  .vv-eventy-roadmap {
    padding: var(--vv-space-8) var(--vv-space-8);
  }

  .vv-eventy-roadmap__head {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-3);
    margin-bottom: var(--vv-space-6);
    align-items: flex-start;
  }

  .vv-eventy-roadmap__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.5rem, 3vw, var(--vv-typography-font-size-3xl));
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-tight);
    color: var(--vv-color-fg-primary);
    margin: 0;
  }

  .vv-eventy-roadmap__list {
    list-style: none;
    margin: 0 0 var(--vv-space-6) 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-3);
  }

  .vv-eventy-roadmap__list li {
    display: flex;
    align-items: flex-start;
    gap: var(--vv-space-3);
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
  }

  .vv-eventy-roadmap__list :global(.vv-icon) {
    color: var(--vv-color-brand-red-700);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .vv-eventy-roadmap__note {
    margin: 0;
    padding: var(--vv-space-4) 0 0 0;
    border-top: 1px solid var(--vv-color-brand-red-100);
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
    text-wrap: pretty;
  }

  .vv-eventy-advantages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-eventy-advantages {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--vv-space-6);
    }
  }

  .vv-eventy-advantage {
    display: flex;
    gap: var(--vv-space-4);
    align-items: flex-start;
    padding: var(--vv-space-5);
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
  }

  .vv-eventy-advantage__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--vv-color-brand-red-50);
    color: var(--vv-color-brand-red-700);
    border-radius: var(--vv-radius-md);
  }

  .vv-eventy-advantage__copy {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-2);
  }

  .vv-eventy-advantage__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-eventy-advantage__body {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
  }

  .vv-eventy-decision {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-eventy-decision {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .vv-eventy-decision__item {
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
    padding: var(--vv-space-6);
  }

  .vv-eventy-decision__q {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-2) 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-eventy-decision__a {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
  }
</style>
