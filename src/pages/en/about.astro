---
/**
 * /en/about — strona „About" Via Viator (EN mirror /o-nas.astro).
 *
 * Identyczna struktura + sekcje co PL, różnice:
 *   - locale="en", dict z en.ts
 *   - tekst lokalny (manifest, archetypy, mini-bio) przepisany na EN
 *   - mapa SVG: nazwy regionów z dict.about.region.regions (EN labels)
 *   - SEO: seoMap.oNas (titleEn/descriptionEn), pathEn
 *
 * Parytet językowy — pierścień jakości #6 QA10 Quality Seal v1.0.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Card from "@components/ui/Card.astro";
import Icon from "@components/ui/Icon.astro";
import Hero from "@components/sections/Hero.astro";
import CTASection from "@components/sections/CTASection.astro";
import { getDictionary } from "@i18n/index";
import { company } from "@data/company";
import { seoMap, buildCanonical, buildAlternates } from "@lib/seo";
import { breadcrumbForRoute } from "@lib/schema";

const locale = "en" as const;
const dict = getDictionary(locale);
const seo = seoMap.oNas;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("oNas", locale, SITE);
const alternates = buildAlternates("oNas", SITE);

const breadcrumbJsonLd = breadcrumbForRoute("oNas", locale, SITE);

// ─────────────────────────────────────────────────────────────────────────────
// Treść lokalna — EN przepisana z parytetem semantycznym wobec PL
// ─────────────────────────────────────────────────────────────────────────────

const missionManifest =
  "Punctuality in the name. Four regions, one phone number, one promise: you'll be on time.";

const archetypes = [
  {
    icon: "shield-check" as const,
    name: "Sage",
    weight: "60%",
    body:
      "We know the parkings, the gates, the traffic. Expertise isn't marketing — it's hours saved on the route.",
  },
  {
    icon: "users" as const,
    name: "Caregiver",
    weight: "30%",
    body:
      "We'll carry the wheelchair, the suitcase too, buckle the child into the seat. Small things nobody rewards.",
  },
  {
    icon: "sparkles" as const,
    name: "Explorer",
    weight: "10%",
    body:
      "Trips, pilgrimages, family weekends. The route isn't just point A to point B.",
  },
];

const patrykBio =
  dict.about.team.patrykBio ??
  "Picks up the phone. Knows the local airports. Decides fast.";

const adrianNote =
  "Company co-founded with Adrian Kaszowski. Adrian stays behind the scenes of operations.";

const patrykInitials = "PT";

// EN labels for region — z dict.about.region.regions (Silesia / Opole / Lesser Poland / Świętokrzyskie)
const regionsEn = dict.about.region.regions;
const hubsEn = dict.about.region.hubs;

// Section titles/labels (parytet EN)
const fleetTableHeaders = {
  model: "Model",
  type: "Type",
  seats: "Seats",
  branding: "Branding",
};

// Type labels — z company.fleet (osobowy/cargo) → EN equivalents
const typeLabelsEn: Record<string, string> = {
  osobowy: "Passenger",
  "osobowy/cargo": "Passenger / cargo",
  cargo: "Cargo",
};

// EN labels for event equipment (przekład z company.eventEquipment)
const eventEquipmentLabelsEn: Record<string, string> = {
  "namiot eventowy": "Event tent",
  "maszyna do popcornu": "Popcorn machine",
  "maszyna do waty cukrowej": "Cotton candy machine",
  "stoły biesiadne": "Banquet tables",
  "ławki biesiadne": "Banquet benches",
};

function translateEquipment(pl: string): string {
  return eventEquipmentLabelsEn[pl] ?? pl;
}
---

<BaseLayout
  title={seo.titleEn}
  description={seo.descriptionEn}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={`${SITE}${seo.ogImage}`}
  jsonLd={breadcrumbJsonLd}
  bodyClass="page-about"
>
  {/* 1. HERO — close-up V logo */}
  <Hero
    eyebrow="Patryk Tomeczek, Adrian Kaszowski, and a van"
    headline={dict.about.h1}
    subhead={dict.about.intro}
    image="/images/brand-detail/brand-logo-close.jpg"
    imageAlt="Via Viator logo on Renault Trafic body — close-up of the letter V."
    align="left"
    tone="default"
    priority={true}
  />

  {/* 2. Why we exist — Mission + manifest */}
  <Section tone="elevated" ariaLabelledby="about-mission-title">
    <Container size="default">
      <div class="vv-about-mission">
        <h2 id="about-mission-title" class="vv-about-section-title">
          {dict.about.mission.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.mission.body}</p>
        <p class="vv-about-mission__manifest">{missionManifest}</p>
      </div>
    </Container>
  </Section>

  {/* 3. How we think — 3 archetypes */}
  <Section tone="default" ariaLabelledby="about-archetypes-title">
    <Container size="default">
      <header class="vv-about-section-head">
        <h2 id="about-archetypes-title" class="vv-about-section-title">
          {dict.about.archetypes.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.archetypes.body}</p>
      </header>

      <ul class="vv-about-archetypes" role="list">
        {
          archetypes.map((a) => (
            <li>
              <Card tone="default" class="vv-about-archetype">
                <div class="vv-about-archetype__head">
                  <span class="vv-about-archetype__icon" aria-hidden="true">
                    <Icon name={a.icon} size={22} />
                  </span>
                  <span class="vv-about-archetype__weight" aria-label={`share ${a.weight}`}>
                    {a.weight}
                  </span>
                </div>
                <h3 class="vv-about-archetype__name">{a.name}</h3>
                <p class="vv-about-archetype__body">{a.body}</p>
              </Card>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  {/* 4. Team — Patryk + Adrian */}
  <Section tone="surface" ariaLabelledby="about-team-title">
    <Container size="default">
      <header class="vv-about-section-head">
        <h2 id="about-team-title" class="vv-about-section-title">
          {dict.about.team.title}
        </h2>
      </header>

      <div class="vv-about-team">
        <Card tone="elevated" class="vv-about-team__card">
          <div class="vv-about-team__avatar" aria-hidden="true">
            <span class="vv-about-team__initials">{patrykInitials}</span>
          </div>
          <div class="vv-about-team__copy">
            <h3 class="vv-about-team__name">{dict.about.team.patrykName}</h3>
            <p class="vv-about-team__role">{dict.about.team.patrykRole}</p>
            <p class="vv-about-team__bio">{patrykBio}</p>
          </div>
        </Card>

        <Card tone="outlined" class="vv-about-team__card vv-about-team__card--note">
          <p class="vv-about-team__note">{adrianNote}</p>
        </Card>
      </div>
    </Container>
  </Section>

  {/* 5. Where we drive — region + hubs + map */}
  <Section tone="default" ariaLabelledby="about-region-title">
    <Container size="default">
      <header class="vv-about-section-head">
        <h2 id="about-region-title" class="vv-about-section-title">
          {dict.about.region.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.region.body}</p>
      </header>

      <div class="vv-about-region">
        <div class="vv-about-region__lists">
          <div class="vv-about-region__group">
            <h3 class="vv-about-region__heading">Regions</h3>
            <ul class="vv-about-region__list" role="list">
              {
                regionsEn.map((r) => (
                  <li>
                    <Icon name="map-pin" size={16} />
                    <span>{r}</span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="vv-about-region__group">
            <h3 class="vv-about-region__heading">Airport hubs</h3>
            <ul class="vv-about-region__list" role="list">
              {
                hubsEn.map((h) => (
                  <li>
                    <Icon name="globe" size={16} />
                    <span>{h}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <figure class="vv-about-region__map">
          <svg
            viewBox="0 0 320 280"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label="Via Viator service area map — Silesia, Opole, Lesser Poland, Świętokrzyskie"
            class="vv-about-region__map-svg"
          >
            <path
              d="M40 60 Q80 30 130 35 Q190 40 250 50 Q285 90 280 140 Q275 200 240 230 Q180 250 110 240 Q60 230 35 180 Q25 130 40 60 Z"
              fill="var(--vv-color-bg-surface)"
              stroke="var(--vv-color-border-subtle)"
              stroke-width="1.5"
            />
            <path
              d="M60 150 Q120 145 200 155 Q260 165 270 200 Q250 230 180 235 Q100 235 55 215 Q40 185 60 150 Z"
              fill="color-mix(in srgb, var(--vv-color-brand-red) 18%, transparent)"
              stroke="var(--vv-color-brand-red)"
              stroke-width="2"
              stroke-dasharray="6 4"
            />
            <g class="vv-about-region__marker">
              <circle cx="155" cy="185" r="9" fill="var(--vv-color-brand-red)" />
              <text x="155" y="208" text-anchor="middle" fill="var(--vv-color-fg-primary)" font-size="11" font-weight="600">Silesia</text>
              <circle cx="110" cy="180" r="6" fill="var(--vv-color-brand-red)" />
              <text x="105" y="170" text-anchor="middle" fill="var(--vv-color-fg-primary)" font-size="10">Opole</text>
              <circle cx="205" cy="200" r="6" fill="var(--vv-color-brand-red)" />
              <text x="220" y="222" text-anchor="middle" fill="var(--vv-color-fg-primary)" font-size="10">Lesser Poland</text>
              <circle cx="225" cy="155" r="6" fill="var(--vv-color-brand-red)" />
              <text x="232" y="145" text-anchor="middle" fill="var(--vv-color-fg-primary)" font-size="10">Świętokrzyskie</text>
            </g>
            <g class="vv-about-region__hubs">
              <polygon points="155,165 161,175 149,175" fill="var(--vv-color-fg-primary)" />
              <polygon points="195,185 201,195 189,195" fill="var(--vv-color-fg-primary)" />
              <polygon points="85,155 91,165 79,165" fill="var(--vv-color-fg-primary)" />
            </g>
          </svg>
          <figcaption class="vv-about-region__map-caption">
            Service area — 4 regions, 3 airport hubs. Schematic visualisation.
          </figcaption>
        </figure>
      </div>
    </Container>
  </Section>

  {/* 6. Fleet */}
  <Section tone="elevated" ariaLabelledby="about-fleet-title">
    <Container size="default">
      <header class="vv-about-section-head">
        <h2 id="about-fleet-title" class="vv-about-section-title">
          {dict.about.fleet.title}
        </h2>
        <p class="vv-about-section-lead">{dict.about.fleet.body}</p>
      </header>

      <div class="vv-about-fleet__table-wrap">
        <table class="vv-about-fleet__table">
          <caption class="visually-hidden">
            List of Via Viator vehicles with type, seat count and branding status.
          </caption>
          <thead>
            <tr>
              <th scope="col">{fleetTableHeaders.model}</th>
              <th scope="col">{fleetTableHeaders.type}</th>
              <th scope="col">{fleetTableHeaders.seats}</th>
              <th scope="col">{fleetTableHeaders.branding}</th>
            </tr>
          </thead>
          <tbody>
            {
              company.fleet.map((v) => (
                <tr>
                  <th scope="row" class="vv-about-fleet__model">
                    {v.model}
                  </th>
                  <td>{typeLabelsEn[v.type] ?? v.type}</td>
                  <td>{v.seats}</td>
                  <td>
                    {v.branded ? (
                      <span class="vv-about-fleet__check" aria-label="Branded yes">
                        <Icon name="check" size={16} />
                      </span>
                    ) : (
                      <span class="vv-about-fleet__dash" aria-label="No branding">
                        —
                      </span>
                    )}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <aside class="vv-about-fleet__events">
        <h3 class="vv-about-fleet__events-title">Plus: event gear</h3>
        <ul class="vv-about-fleet__events-list" role="list">
          {
            company.eventEquipment.map((eq) => (
              <li>
                <Icon name="check" size={16} />
                <span>{translateEquipment(eq)}</span>
              </li>
            ))
          }
        </ul>
        {company.eventEquipmentPlanned.length > 0 && (
          <p class="vv-about-fleet__events-planned">
            From autumn 2026 we add:{" "}
            <strong>
              {company.eventEquipmentPlanned.map(translateEquipment).join(", ")}
            </strong>.
          </p>
        )}
      </aside>
    </Container>
  </Section>

  {/* 7. Final CTA */}
  <CTASection
    tone="brand"
    title="Plan a transfer, trip or rental with us"
    body="A short brief: from, to, when, how many. We reply as fast as our promise allows."
    primaryCta={{
      label: dict.cta.sendBrief,
      href: "/en/contact",
      ariaLabel: "Go to the contact form",
    }}
    secondaryCta={{
      label: `Call: ${company.phoneDisplay}`,
      href: company.phoneHref,
      ariaLabel: `Call: ${company.phoneDisplay}`,
    }}
    align="center"
  />
</BaseLayout>

<style>
  /* Wspólne style — identyczne z /o-nas.astro dla parytetu wizualnego. */

  .vv-about-section-head {
    margin: 0 0 var(--vv-space-10) 0;
    max-width: 64ch;
  }

  .vv-about-section-title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 3.5vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-3) 0;
    text-wrap: balance;
  }

  .vv-about-section-lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  .vv-about-mission {
    max-width: 65ch;
  }

  .vv-about-mission__manifest {
    margin: var(--vv-space-6) 0 0 0;
    padding: var(--vv-space-5) var(--vv-space-6);
    background-color: var(--vv-color-bg-page);
    border-left: 4px solid var(--vv-color-brand-red);
    border-radius: var(--vv-radius-md);
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-semibold);
    color: var(--vv-color-fg-primary);
    line-height: var(--vv-typography-line-height-snug);
    text-wrap: balance;
  }

  .vv-about-archetypes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-about-archetypes {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .vv-about-archetype {
    height: 100%;
  }

  .vv-about-archetype__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--vv-space-3);
  }

  .vv-about-archetype__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--vv-radius-md);
    background-color: var(--vv-color-brand-red-50);
    color: var(--vv-color-brand-red-700);
  }

  .vv-about-archetype__weight {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-sm);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-brand-red-700);
    letter-spacing: var(--vv-typography-letter-spacing-wider);
  }

  .vv-about-archetype__name {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-about-archetype__body {
    font-size: var(--vv-typography-font-size-base);
    color: var(--vv-color-fg-secondary);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
  }

  .vv-about-team {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-about-team {
      grid-template-columns: 1.4fr 1fr;
      align-items: start;
    }
  }

  .vv-about-team__card {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-5);
  }

  @media (min-width: 640px) {
    .vv-about-team__card:not(.vv-about-team__card--note) {
      flex-direction: row;
      align-items: center;
    }
  }

  .vv-about-team__card--note {
    justify-content: center;
  }

  .vv-about-team__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    flex-shrink: 0;
    border-radius: 50%;
    background: linear-gradient(
      135deg,
      var(--vv-color-brand-red) 0%,
      var(--vv-color-brand-red-700) 100%
    );
    box-shadow: var(--vv-shadow-md);
  }

  .vv-about-team__initials {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-3xl);
    font-weight: var(--vv-typography-font-weight-extrabold);
    color: var(--vv-color-brand-white);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
  }

  .vv-about-team__copy {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-2);
  }

  .vv-about-team__name {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0;
    line-height: var(--vv-typography-line-height-snug);
  }

  .vv-about-team__role {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--vv-typography-letter-spacing-wider);
    color: var(--vv-color-brand-red-700);
    margin: 0;
  }

  .vv-about-team__bio {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
  }

  .vv-about-team__note {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    font-style: italic;
  }

  .vv-about-region {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-8);
  }

  @media (min-width: 1024px) {
    .vv-about-region {
      grid-template-columns: 1fr 1fr;
      gap: var(--vv-space-12);
      align-items: start;
    }
  }

  .vv-about-region__lists {
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-6);
  }

  .vv-about-region__group {
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
    padding: var(--vv-space-6);
  }

  .vv-about-region__heading {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-4) 0;
  }

  .vv-about-region__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--vv-space-3);
  }

  .vv-about-region__list li {
    display: inline-flex;
    align-items: center;
    gap: var(--vv-space-2);
    padding: var(--vv-space-2) var(--vv-space-4);
    background-color: var(--vv-color-bg-surface);
    border-radius: var(--vv-radius-full);
    font-size: var(--vv-typography-font-size-sm);
    font-weight: var(--vv-typography-font-weight-medium);
    color: var(--vv-color-fg-primary);
  }

  .vv-about-region__list li :global(.vv-icon) {
    color: var(--vv-color-brand-red-700);
    flex-shrink: 0;
  }

  .vv-about-region__map {
    margin: 0;
    background-color: var(--vv-color-bg-elevated);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
    padding: var(--vv-space-6);
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-3);
  }

  .vv-about-region__map-svg {
    width: 100%;
    max-width: 380px;
    height: auto;
    margin-inline: auto;
    display: block;
  }

  .vv-about-region__map-caption {
    font-size: var(--vv-typography-font-size-sm);
    color: var(--vv-color-fg-muted);
    text-align: center;
    line-height: var(--vv-typography-line-height-relaxed);
  }

  .vv-about-fleet__table-wrap {
    overflow-x: auto;
    border-radius: var(--vv-radius-lg);
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    margin: 0 0 var(--vv-space-8) 0;
  }

  .vv-about-fleet__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--vv-typography-font-size-base);
  }

  .vv-about-fleet__table thead th {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xs);
    font-weight: var(--vv-typography-font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--vv-typography-letter-spacing-wider);
    color: var(--vv-color-fg-muted);
    text-align: left;
