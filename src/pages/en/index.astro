---
/**
 * Homepage EN — `/en/`
 *
 * Pełny mirror `/index.astro` w EN locale.
 * Te same komponenty, te same sekcje — różnice tylko w locale + SEO paths/copy.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import SectionIndex from "@components/ui/SectionIndex.astro";
import HomeHero from "@components/sections/HomeHero.astro";
import SegmentGrid from "@components/sections/SegmentGrid.astro";
import AtlasPoludnia from "@components/sections/AtlasPoludnia.astro";
import FeatureGrid from "@components/sections/FeatureGrid.astro";
import FleetCards from "@components/sections/FleetCards.astro";
import CTASection from "@components/sections/CTASection.astro";
import { getDictionary } from "@i18n/index";
import { company } from "@data/company";
import { seoMap, buildCanonical, buildAlternates } from "@lib/seo";
import {
  organizationSchema,
  websiteSchema,
  localBusinessSchema,
} from "@lib/schema";

const locale = "en" as const;
const dict = getDictionary(locale);
const seo = seoMap.home;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("home", locale, SITE);
const alternates = buildAlternates("home", SITE);

const jsonLd: Record<string, unknown>[] = [
  organizationSchema(SITE),
  websiteSchema(SITE),
  localBusinessSchema(SITE),
];

// HomeHero v2 uses /images/hero/hero-03-trafic-arena-side.webp internally,
// but og:image keeps the legacy hero-01 (already indexed by Facebook crawler).
const heroImage = "/images/hero/hero-01-lichen-trafic.jpg";

const whyUsIcons = ["clock", "map-pin", "shield-check", "phone"] as const;
const whyUsItems = dict.home.sectionWhyUs.points.map((p, i) => ({
  icon: whyUsIcons[i],
  title: p.title,
  body: p.body,
}));

// Fleet — M09: FleetCards component (Trafic + Master) with 3D tilt + parallax depth.
// Data (model, image, specs, usage) encapsulated in the component with PL/EN fallback.
---

<BaseLayout
  title={seo.titleEn}
  description={seo.descriptionEn}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={`${SITE}${heroImage}`}
  jsonLd={jsonLd}
  bodyClass="page-home"
>
  {/* 1. HERO — Editorial Split „Manifest on a spread" (HomeHero v2) */}
  <HomeHero locale={locale} />

  {/* 2. What we do — section-level reveal */}
  <Section tone="default" ariaLabelledby="home-what-title">
    <Container size="default">
      <div class="vv-home-what vv-reveal">
        <SectionIndex number={2} label="What we do" />
        <h2 id="home-what-title" class="vv-home-what__title">
          {dict.home.sectionWhatWeDo.title}
        </h2>
        <p class="vv-home-what__body">{dict.home.sectionWhatWeDo.body}</p>
      </div>
    </Container>
  </Section>

  {/* 3. Who we drive for — head reveals; SegmentGrid cascades children */}
  <Section tone="elevated" id="dla-kogo" ariaLabelledby="home-segments-title">
    <Container size="wide">
      <div class="vv-home-segments__head vv-reveal">
        <SectionIndex number={3} label="Who we drive for" />
        <h2 id="home-segments-title" class="vv-home-segments__title">
          {dict.home.sectionForWhom.title}
        </h2>
        <p class="vv-home-segments__body">{dict.home.sectionForWhom.body}</p>
        <p class="vv-home-segments__callout">
          {dict.home.sectionForWhom.segmentsCallout}
        </p>
      </div>
      <SegmentGrid locale={locale} />
    </Container>
  </Section>

  {/* 4. Southern Atlas (Wow#1) — interactive map: 4 regions + 3 airport hubs + base */}
  <AtlasPoludnia locale={locale} variant="full" />

  {/* 5. Our fleet — M09: FleetCards with 3D tilt + parallax depth (compact). */}
  <Section tone="default" ariaLabelledby="home-fleet-title">
    <Container size="default">
      <div class="vv-home-fleet__head vv-reveal">
        <SectionIndex number={4} label="Fleet" />
        <h2 id="home-fleet-title" class="vv-home-fleet__title">
          {dict.home.sectionFleet.title}
        </h2>
        <p class="vv-home-fleet__body">{dict.home.sectionFleet.body}</p>
      </div>
      <FleetCards locale={locale} variant="compact" />

      <figure class="vv-home-fleet__a6 vv-reveal">
        <picture>
          <source srcset="/images/brand-detail/via-viator-a6-flyer.webp" type="image/webp" />
          <img
            src="/images/brand-detail/via-viator-a6-flyer.png"
            alt="Via Viator A6 poster — phone number and fleet"
            loading="lazy"
            decoding="async"
            width="620"
            height="876"
          />
        </picture>
        <figcaption>
          A6 poster — the paper card we leave inside the vehicle after every booking.
        </figcaption>
      </figure>
    </Container>
  </Section>

  {/* 6. Why us — title reveals; FeatureGrid cascades children */}
  <Section tone="elevated" ariaLabelledby="home-whyus-title">
    <Container size="default">
      <div class="vv-home-whyus__head vv-reveal">
        <SectionIndex number={5} label="Why us" />
        <h2 id="home-whyus-title" class="vv-home-whyus__title">
          {dict.home.sectionWhyUs.title}
        </h2>
      </div>
      <FeatureGrid items={whyUsItems} columns={2} tone="default" />
    </Container>
  </Section>

  {/* 7. Trusted by */}
  <Section tone="default" tight ariaLabelledby="home-trust-title">
    <Container size="narrow">
      <div class="vv-home-trust vv-reveal">
        <SectionIndex number={6} label="Trusted by" />
        <h2 id="home-trust-title" class="vv-home-trust__title">
          {dict.home.sectionTrust.title}
        </h2>
        <p class="vv-home-trust__body">{dict.home.sectionTrust.body}</p>
        <p class="vv-home-trust__placeholder">
          {dict.home.sectionTrust.placeholder}
        </p>
      </div>
    </Container>
  </Section>

  {/* 8. Final CTA */}
  <CTASection
    tone="brand"
    title={dict.home.sectionContactTeaser.title}
    body={dict.home.sectionContactTeaser.body}
    primaryCta={{
      label: dict.cta.requestQuote,
      href: "/en/contact",
    }}
    secondaryCta={{
      label: dict.cta.callNow,
      href: company.phoneHref,
    }}
    align="center"
  />
</BaseLayout>

<style>
  /* What we do */
  .vv-home-what {
    max-width: 65ch;
  }

  .vv-home-what__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-5) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-home-what__body {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* Who we drive for — head */
  .vv-home-segments__head {
    max-width: 70ch;
    margin: 0 0 var(--vv-space-10) 0;
  }

  .vv-home-segments__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-home-segments__body {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0 0 var(--vv-space-4) 0;
  }

  .vv-home-segments__callout {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-base);
    font-weight: var(--vv-typography-font-weight-semibold);
    color: var(--vv-color-brand-red-700);
    margin: 0;
  }

  /* Fleet */
  .vv-home-fleet__head {
    max-width: 65ch;
    margin: 0 0 var(--vv-space-10) 0;
  }

  .vv-home-fleet__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-home-fleet__body {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
  }

  .vv-home-fleet__a6 {
    margin: var(--vv-space-12) auto 0;
    max-width: 420px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--vv-space-3);
  }
  .vv-home-fleet__a6 picture {
    display: block;
    width: 100%;
    aspect-ratio: 1240 / 1748;
    background: var(--vv-color-bg-elevated);
    border-radius: var(--vv-radius-md);
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 16px 40px rgba(0, 0, 0, 0.12);
  }
  .vv-home-fleet__a6 img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .vv-home-fleet__a6 figcaption {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-xs);
    letter-spacing: 0.06em;
    color: var(--vv-color-fg-muted);
    max-width: 36ch;
  }

  /* Fleet cards M09 — own styling in `FleetCards.astro` (3D tilt + parallax). */

  /* Why us */
  .vv-home-whyus__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-10) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  /* Trust */
  .vv-home-trust {
    text-align: center;
    max-width: 60ch;
    margin-inline: auto;
  }

  /* Centered SectionIndex w trust block (mirror /index.astro). */
  .vv-home-trust :global(.section-index) {
    justify-content: center;
  }

  /* Why-us head wrapper — daje miejsce SectionIndex nad h2. */
  .vv-home-whyus__head {
    margin: 0 0 var(--vv-space-10) 0;
    max-width: 70ch;
  }

  .vv-home-whyus__head .vv-home-whyus__title {
    margin: 0;
  }

  .vv-home-trust__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-snug);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
  }

  .vv-home-trust__body {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0 0 var(--vv-space-3) 0;
  }

  .vv-home-trust__placeholder {
    font-size: var(--vv-typography-font-size-sm);
    color: var(--vv-color-fg-muted);
    font-style: italic;
    margin: 0;
  }
</style>
