---
/**
 * /transfery-korporacyjne — P1 Korpo (PL).
 *
 * Sekcje (zgodnie z briefem):
 *  1. Hero — image hero-02-arena-gliwice.jpg, Q-CTA, time-to-quote badge
 *  2. „Co dostajesz" — what.title + what.body + grid punktów (what.points)
 *  3. „Jak pracujemy" — howWeWork.title + howWeWork.body + 4 kroki numerowane
 *  4. „Decision Criteria" — FAQAccordion z decisionList.items (Q&A)
 *  5. Social proof — placeholder (klient nie udostępnił logotypów)
 *  6. FAQ — FAQAccordion z faq.items
 *  7. CTA finalna — CTASection tone="brand", Q-CTA segmentu
 *
 * SEO:
 *  - seoMap.korpo (titlePl, descriptionPl)
 *  - canonical via buildCanonical("korpo", "pl")
 *  - alternates via buildAlternates("korpo")
 *  - JSON-LD: serviceForSegment + breadcrumbForRoute + faqSchema
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Badge from "@components/ui/Badge.astro";
import Icon from "@components/ui/Icon.astro";
import Hero from "@components/sections/Hero.astro";
import FAQAccordion from "@components/sections/FAQAccordion.astro";
import CTASection from "@components/sections/CTASection.astro";
import { getDictionary } from "@i18n/index";
import { company } from "@data/company";
import { seoMap, buildCanonical, buildAlternates } from "@lib/seo";
import { serviceForSegment, breadcrumbForRoute, faqSchema } from "@lib/schema";

const locale = "pl" as const;
const dict = getDictionary(locale);
const seg = dict.segments.korpo;
const seo = seoMap.korpo;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("korpo", locale, SITE);
const alternates = buildAlternates("korpo", SITE);

// JSON-LD: Service + Breadcrumb + FAQ
const jsonLd: Record<string, unknown>[] = [
  serviceForSegment("korpo", locale, SITE),
  breadcrumbForRoute("korpo", locale, SITE),
  faqSchema([...seg.faq.items]),
];

const heroImage = "/images/hero/hero-02-arena-gliwice.jpg";
const heroImageAlt =
  "Renault Trafic Via Viator na podjeździe pod halą Arena Gliwice — transfer korporacyjny.";

// Decision list jako Q&A → FAQAccordion-compatible
const decisionItems = [...seg.decisionList.items];
const faqItems = [...seg.faq.items];
---

<BaseLayout
  title={seo.titlePl}
  description={seo.descriptionPl}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={`${SITE}${heroImage}`}
  jsonLd={jsonLd}
  bodyClass="page-segment page-segment--korpo"
>
  {/* 1. HERO — z time-to-quote badge obok */}
  <Hero
    headline={seg.heroHeadline}
    subhead={seg.heroSubhead}
    image={heroImage}
    imageAlt={heroImageAlt}
    primaryCta={{
      label: seg.cta,
      href: "/kontakt?segment=korpo#rfq",
    }}
    secondaryCta={{
      label: seg.ctaSecondary,
      href: company.phoneHref,
    }}
    align="left"
    tone="default"
    priority={true}
  />

  {/* Pasek z time-to-quote badge — pod hero */}
  <Section tone="default" tight ariaLabel="Czas odpowiedzi">
    <Container size="wide">
      <div class="vv-seg-meta">
        <Badge tone="brand" size="md">
          <Icon name="clock" size={12} />
          <span>{seg.timeToQuote}</span>
        </Badge>
        <span class="vv-seg-meta__hint">
          Tryb pracy: poniedziałek–piątek 7:00–20:00. Awaryjnie 24/7 ten sam
          numer.
        </span>
      </div>
    </Container>
  </Section>

  {/* 2. „Co dostajesz" */}
  <Section tone="default" ariaLabelledby="seg-what-title">
    <Container size="default">
      <div class="vv-seg-block">
        <h2 id="seg-what-title" class="vv-seg-block__title">
          {seg.what.title}
        </h2>
        <p class="vv-seg-block__lead">{seg.what.body}</p>
        <ul class="vv-seg-list" role="list">
          {
            seg.what.points.map((p) => (
              <li class="vv-seg-list__item">
                <span class="vv-seg-list__icon" aria-hidden="true">
                  <Icon name="check" size={18} />
                </span>
                <span class="vv-seg-list__text">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </Section>

  {/* 3. „Jak pracujemy" — 4 kroki numerowane */}
  <Section tone="elevated" ariaLabelledby="seg-how-title">
    <Container size="default">
      <div class="vv-seg-block">
        <h2 id="seg-how-title" class="vv-seg-block__title">
          {seg.howWeWork.title}
        </h2>
        <p class="vv-seg-block__lead">{seg.howWeWork.body}</p>
        <ol class="vv-seg-steps" role="list">
          {
            seg.howWeWork.steps.map((s, i) => (
              <li class="vv-seg-step">
                <span class="vv-seg-step__num" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="vv-seg-step__title">{s.title}</h3>
                <p class="vv-seg-step__body">{s.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </Container>
  </Section>

  {/* 4. Decision Criteria — Q&A akordeon */}
  <Section tone="default" ariaLabelledby="seg-decision-title">
    <Container size="default">
      <div class="vv-seg-block">
        <h2 id="seg-decision-title" class="vv-seg-block__title">
          {seg.decisionList.title}
        </h2>
        <p class="vv-seg-block__lead">{seg.decisionList.body}</p>
      </div>
      <FAQAccordion items={decisionItems} defaultOpenFirst={true} />
    </Container>
  </Section>

  {/* 5. Social proof — placeholder */}
  <Section tone="elevated" tight ariaLabelledby="seg-trust-title">
    <Container size="narrow">
      <div class="vv-seg-trust">
        <h2 id="seg-trust-title" class="vv-seg-trust__title">
          Z kim pracujemy
        </h2>
        <p class="vv-seg-trust__body">
          Pracujemy m.in. dla firm produkcyjnych i biurowych z Katowic, Gliwic,
          Krakowa i Wrocławia — od kilkuosobowych zespołów po działy z
          regularną rotacją gości zagranicznych. Lista referencji rośnie z
          każdym kursem; konkretne kontakty B2B wysyłamy na życzenie po
          pierwszym briefie.
        </p>
      </div>
    </Container>
  </Section>

  {/* 6. FAQ */}
  <Section tone="default" ariaLabelledby="seg-faq-title">
    <Container size="default">
      <h2 id="seg-faq-title" class="vv-seg-block__title">
        {seg.faq.title}
      </h2>
      <FAQAccordion items={faqItems} />
    </Container>
  </Section>

  {/* 7. CTA finalna */}
  <CTASection
    tone="brand"
    title={seg.cta}
    body={seg.heroSubhead}
    primaryCta={{
      label: dict.cta.requestQuote,
      href: "/kontakt?segment=korpo#rfq",
    }}
    secondaryCta={{
      label: dict.cta.callNow,
      href: company.phoneHref,
    }}
    align="center"
  />
</BaseLayout>

<style>
  /* Meta pasek */
  .vv-seg-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--vv-space-4);
    padding-block: var(--vv-space-2);
    border-block: 1px solid var(--vv-color-border-subtle);
  }

  .vv-seg-meta__hint {
    font-size: var(--vv-typography-font-size-sm);
    color: var(--vv-color-fg-muted);
    line-height: var(--vv-typography-line-height-relaxed);
  }

  /* Wspólny block — title + lead */
  .vv-seg-block {
    max-width: 72ch;
    margin: 0 0 var(--vv-space-8) 0;
  }

  .vv-seg-block__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-seg-block__lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* Lista „Co dostajesz" */
  .vv-seg-list {
    list-style: none;
    margin: var(--vv-space-6) 0 0 0;
    padding: 0;
    display: grid;
    gap: var(--vv-space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .vv-seg-list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--vv-space-5) var(--vv-space-8);
    }
  }

  .vv-seg-list__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--vv-space-3);
    align-items: start;
  }

  .vv-seg-list__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--vv-radius-full);
    background-color: var(--vv-color-brand-red-50);
    color: var(--vv-color-brand-red-700);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .vv-seg-list__text {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
  }

  /* Steps „Jak pracujemy" */
  .vv-seg-steps {
    list-style: none;
    margin: var(--vv-space-8) 0 0 0;
    padding: 0;
    display: grid;
    gap: var(--vv-space-5);
    grid-template-columns: 1fr;
    counter-reset: step;
  }

  @media (min-width: 768px) {
    .vv-seg-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .vv-seg-steps {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .vv-seg-step {
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-lg);
    padding: var(--vv-space-6);
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-2);
    position: relative;
  }

  .vv-seg-step__num {
    font-family: var(--vv-typography-font-family-mono);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-brand-red-700);
    line-height: 1;
    margin-bottom: var(--vv-space-2);
  }

  .vv-seg-step__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xl);
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-snug);
    margin: 0;
    color: var(--vv-color-fg-primary);
  }

  .vv-seg-step__body {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
  }

  /* Trust */
  .vv-seg-trust {
    text-align: center;
    max-width: 65ch;
    margin-inline: auto;
  }

  .vv-seg-trust__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-2xl);
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-snug);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
  }

  .vv-seg-trust__body {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }
</style>
