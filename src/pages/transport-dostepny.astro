---
/**
 * /transport-dostepny — P3 Transport dostępny / DPS-y i fundacje (PL).
 *
 * Sekcje:
 *  1. Hero — image service-airport-mobile.jpg (pion, kontekst care)
 *  2. „Czym jest u nas transport dostępny" — what.title + what.body + lista
 *  3. „Czego pilnujemy w trasie" — FeatureGrid 4 punkty (kierowca, czas, fotelik, kontakt)
 *  4. „Decision Criteria" — FAQAccordion z decisionList.items
 *  5. „Procedura testowa bez umowy" — sekcja edukacyjna (P3 buyer persona)
 *  6. FAQ — FAQAccordion z faq.items
 *  7. CTA finalna — CTASection tone="brand"
 *
 * SEO: seoMap.dostepny, JSON-LD: service + breadcrumb + faq.
 */

import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Section from "@components/ui/Section.astro";
import Badge from "@components/ui/Badge.astro";
import Icon from "@components/ui/Icon.astro";
import SectionIndex from "@components/ui/SectionIndex.astro";
import Hero from "@components/sections/Hero.astro";
import FeatureGrid from "@components/sections/FeatureGrid.astro";
import FAQAccordion from "@components/sections/FAQAccordion.astro";
import CTASection from "@components/sections/CTASection.astro";
import PullQuote from "@components/sections/PullQuote.astro";
import { getDictionary } from "@i18n/index";
import { company } from "@data/company";
import { seoMap, buildCanonical, buildAlternates } from "@lib/seo";
import { serviceForSegment, breadcrumbForRoute, faqSchema } from "@lib/schema";

const locale = "pl" as const;
const dict = getDictionary(locale);
const seg = dict.segments.dostepny;
const seo = seoMap.dostepny;

const SITE = (
  import.meta.env.PUBLIC_SITE_URL ?? "https://viaviator.pl"
).replace(/\/$/, "");

const canonical = buildCanonical("dostepny", locale, SITE);
const alternates = buildAlternates("dostepny", SITE);

const jsonLd: Record<string, unknown>[] = [
  serviceForSegment("dostepny", locale, SITE),
  breadcrumbForRoute("dostepny", locale, SITE),
  faqSchema([...seg.faq.items]),
];

const heroImage = "/images/services/service-airport-mobile.jpg";
const heroImageAlt =
  "Renault Trafic Via Viator — asysta przy bagażu, kontekst opieki nad pasażerem.";

// „Czego pilnujemy w trasie" — 4 punkty (kompetencja operacyjna, zgodna z briefem)
const driveRules = [
  {
    icon: "shield-check" as const,
    title: "Kierowca przeszkolony z PRM",
    body:
      "Szkolenie z transferu pasażera, mocowania wózka i asysty przy wsiadaniu. Procedurę pokazujemy na spotkaniu w placówce.",
  },
  {
    icon: "clock" as const,
    title: "Czas dopasowany do pasażera",
    body:
      "Nikt nie pogania. Wsiadanie i wysiadanie w tempie pasażera — to standard, nie wyjątek.",
  },
  {
    icon: "users" as const,
    title: "Fotelik dla dziecka aktywny",
    body:
      "Dla dzieci z niepełnosprawnościami fotelik aktywny lub stabilizujący — jeśli zgłosicie w briefie, mamy w pojeździe na trasie.",
  },
  {
    icon: "phone" as const,
    title: "Bezpośredni kontakt z opiekunem",
    body:
      "Kierowca ma numer do opiekuna/rodzica. SMS po wyjeździe, SMS przy dotarciu, telefon w razie zmiany sytuacji.",
  },
];

const decisionItems = [...seg.decisionList.items];
const faqItems = [...seg.faq.items];
---

<BaseLayout
  title={seo.titlePl}
  description={seo.descriptionPl}
  locale={locale}
  canonical={canonical}
  alternates={alternates}
  ogImage={`${SITE}${heroImage}`}
  jsonLd={jsonLd}
  bodyClass="page-segment page-segment--dostepny"
>
  {/* 1. HERO */}
  <Hero
    headline={seg.heroHeadline}
    subhead={seg.heroSubhead}
    image={heroImage}
    imageAlt={heroImageAlt}
    primaryCta={{
      label: seg.cta,
      href: "/kontakt?segment=dostepny#koordynator",
    }}
    secondaryCta={{
      label: seg.ctaSecondary,
      href: company.phoneHref,
    }}
    align="left"
    tone="default"
    priority={true}
  />

  {/* Meta — time-to-quote dla P3 jest dłuższy (umowy 8-16 tyg.) */}
  <Section tone="default" tight ariaLabel="Czas decyzji">
    <Container size="wide">
      <div class="vv-seg-meta">
        <Badge tone="brand" size="md">
          <Icon name="clock" size={12} />
          <span>Rozmowa w 30 minut, umowa w 8–16 tygodni</span>
        </Badge>
        <span class="vv-seg-meta__hint">
          Krótka rozmowa wstępna w 30 minut. Umowa ramowa — proces 8–16
          tygodni, w trybie placówki/fundacji.
        </span>
      </div>
    </Container>
  </Section>

  {/* 2. Czym jest u nas transport dostępny */}
  <Section tone="default" ariaLabelledby="seg-what-title">
    <Container size="default">
      <div class="vv-seg-block">
        <SectionIndex number={2} label="Czym jest transport dostępny" />
        <h2 id="seg-what-title" class="vv-seg-block__title">
          {seg.what.title}
        </h2>
        <p class="vv-seg-block__lead">{seg.what.body}</p>
        <ul class="vv-seg-list" role="list">
          {
            seg.what.points.map((p) => (
              <li class="vv-seg-list__item">
                <span class="vv-seg-list__icon" aria-hidden="true">
                  <Icon name="check" size={18} />
                </span>
                <span class="vv-seg-list__text">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </Section>

  {/* 3. Czego pilnujemy w trasie + pull-quote z buyer persony Tomasza (P3). */}
  <Section tone="elevated" ariaLabelledby="seg-rules-title">
    <Container size="default">
      <div class="vv-seg-block">
        <SectionIndex number={3} label="Czego pilnujemy w trasie" />
        <h2 id="seg-rules-title" class="vv-seg-block__title">
          Czego pilnujemy w trasie
        </h2>
        <p class="vv-seg-block__lead">
          Cztery rzeczy, które robimy zawsze — bez pytania o dopłatę, bez
          tłumaczenia, że „to nie jest w cenniku".
        </p>
      </div>
      <FeatureGrid items={driveRules} columns={2} tone="default" />

      <PullQuote
        quote="Nikt nie pogania pasażera. Wsiadanie i wysiadanie w tempie podopiecznego — to jest dla mnie standard, nie wyjątek."
        attribution="Tomasz, koordynator DPS"
      />
    </Container>
  </Section>

  {/* 4. Decision Criteria */}
  <Section tone="default" ariaLabelledby="seg-decision-title">
    <Container size="default">
      <div class="vv-seg-block">
        <SectionIndex number={4} label="Kryteria decyzji" />
        <h2 id="seg-decision-title" class="vv-seg-block__title">
          {seg.decisionList.title}
        </h2>
        <p class="vv-seg-block__lead">{seg.decisionList.body}</p>
      </div>
      <FAQAccordion items={decisionItems} defaultOpenFirst={true} />
    </Container>
  </Section>

  {/* 5. Procedura testowa bez umowy — sekcja edukacyjna P3 */}
  <Section tone="surface" ariaLabelledby="seg-test-title">
    <Container size="default">
      <div class="vv-seg-test">
        <h2 id="seg-test-title" class="vv-seg-test__title">
          Procedura testowa — bez umowy, bez zobowiązań
        </h2>
        <p class="vv-seg-test__lead">
          Wiemy, że umowa 12-miesięczna z nowym przewoźnikiem to nie jest
          decyzja na lekko. Dlatego proponujemy 8 tygodni pracy testowej, na
          pojedynczych kursach, bez podpisywania umowy ramowej.
        </p>
        <ul class="vv-seg-test__list" role="list">
          <li>
            <strong>Tydzień 1–4:</strong> robimy kursy „na życzenie" — Wy
            zgłaszacie potrzebę z 24-godzinnym wyprzedzeniem, my realizujemy,
            fakturujemy pojedynczo.
          </li>
          <li>
            <strong>Tydzień 5–8:</strong> robimy 1–2 kursy w stałym
            harmonogramie tygodniowym — sprawdzacie, jak wygląda powtarzalność.
          </li>
          <li>
            <strong>Tydzień 8:</strong> spotkanie podsumowujące. Jeśli pasuje
            — przechodzimy na umowę 12-miesięczną z lockowaną stawką. Jeśli nie
            — rozchodzimy się bez śladu w księgowości.
          </li>
        </ul>
        <p class="vv-seg-test__note">
          To są nasze warunki standardowe — niezależnie od wielkości placówki
          i liczby tras. Pierwsze spotkanie u Was, bez kosztu.
        </p>
      </div>
    </Container>
  </Section>

  {/* 6. FAQ */}
  <Section tone="default" ariaLabelledby="seg-faq-title">
    <Container size="default">
      <h2 id="seg-faq-title" class="vv-seg-block__title">
        {seg.faq.title}
      </h2>
      <FAQAccordion items={faqItems} />
    </Container>
  </Section>

  {/* 7. CTA finalna */}
  <CTASection
    tone="brand"
    title={seg.cta}
    body={seg.heroSubhead}
    primaryCta={{
      label: dict.cta.bookCall,
      href: "/kontakt?segment=dostepny#koordynator",
    }}
    secondaryCta={{
      label: dict.cta.callNow,
      href: company.phoneHref,
    }}
    align="center"
  />
</BaseLayout>

<style>
  .vv-seg-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--vv-space-4);
    padding-block: var(--vv-space-2);
    border-block: 1px solid var(--vv-color-border-subtle);
  }

  .vv-seg-meta__hint {
    font-size: var(--vv-typography-font-size-sm);
    color: var(--vv-color-fg-muted);
    line-height: var(--vv-typography-line-height-relaxed);
  }

  .vv-seg-block {
    max-width: 72ch;
    margin: 0 0 var(--vv-space-8) 0;
  }

  .vv-seg-block__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-seg-block__lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  .vv-seg-list {
    list-style: none;
    margin: var(--vv-space-6) 0 0 0;
    padding: 0;
    display: grid;
    gap: var(--vv-space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .vv-seg-list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--vv-space-5) var(--vv-space-8);
    }
  }

  .vv-seg-list__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--vv-space-3);
    align-items: start;
  }

  .vv-seg-list__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--vv-radius-full);
    background-color: var(--vv-color-brand-red-50);
    color: var(--vv-color-brand-red-700);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .vv-seg-list__text {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
  }

  /* Procedura testowa */
  .vv-seg-test {
    max-width: 72ch;
  }

  .vv-seg-test__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    margin: 0 0 var(--vv-space-4) 0;
    color: var(--vv-color-fg-primary);
    text-wrap: balance;
  }

  .vv-seg-test__lead {
    font-size: var(--vv-typography-font-size-lg);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0 0 var(--vv-space-6) 0;
    text-wrap: pretty;
  }

  .vv-seg-test__list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--vv-space-6) 0;
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-4);
  }

  .vv-seg-test__list li {
    padding-left: var(--vv-space-5);
    border-left: 3px solid var(--vv-color-brand-red);
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-primary);
  }

  .vv-seg-test__list strong {
    font-weight: var(--vv-typography-font-weight-bold);
    color: var(--vv-color-brand-red-700);
  }

  .vv-seg-test__note {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-muted);
    font-style: italic;
    margin: 0;
  }
</style>
