---
/**
 * AtlasPoludnia — Wow#1 Atlas Południa.
 *
 * Sekcja: interaktywna SVG mapa południowej Polski.
 *  - 4 województwa jako klikalne paths (highlight on hover/focus, tooltip)
 *  - 3 huby lotniskowe jako klikalne circles (cta → /transfery-korporacyjne)
 *  - 1 baza Tarnowskie Góry — distinguished marker (większy, czarny, oznacza dom)
 *  - 3 trasy hub→base — stroke-dasharray draw-on przy hover huba
 *
 * Variant:
 *  - "full"   = home page; pełna kompozycja, prawa kolumna = info card
 *  - "compact" = /o-nas page; mniejszy panel/brak panelu, sama mapa
 *
 * Stack:
 *  - Inline SVG (~6 KB gzip), zero zewnętrznych assetów.
 *  - Vanilla JS (~1.5 KB gzip) — bindings na data-attributes,
 *    swap text content w info card, scroll/navigate na klik huba/base.
 *  - CSS scroll-driven dla initial reveal (już dziedziczy `.vv-reveal`),
 *    custom dasharray animation dla tras (per-hub on hover).
 *
 * A11y:
 *  - SVG: role="img" + aria-labelledby + <title> jako pierwszy child
 *  - Regions/hubs/base: <button> z aria-label, focus-visible outline,
 *    tab-navigable, click target ≥ 44×44px (mobile)
 *  - prefers-reduced-motion: zero animations, end-state instant
 *  - aria-live="polite" region pod mapą — anonsuje nowy state info card
 *
 * Performance:
 *  - JS overhead: < 2 KB raw (no deps, no event throttling needed —
 *    pointerenter/leave to natural events, no rAF)
 *  - Initial render: pure HTML, no JS dla baseline
 *  - SSR safe — script runs after page load
 */

import { getDictionary, type Locale } from "@i18n/index";
import {
  regions,
  hubs,
  baseLocation,
  routePathFromBaseToHub,
} from "@data/atlas";

interface Props {
  locale: Locale;
  /** Wariant kompozycji: "full" (home) lub "compact" (/o-nas). */
  variant?: "full" | "compact";
}

const { locale, variant = "full" } = Astro.props;
const dict = getDictionary(locale);

// Helpers do i18n — tKey wrap z fallbackiem identycznym jak SegmentGrid.
function tKey(path: string): string {
  const v = path
    .split(".")
    .reduce<unknown>(
      (acc, k) =>
        acc && typeof acc === "object"
          ? (acc as Record<string, unknown>)[k]
          : undefined,
      dict,
    );
  return typeof v === "string" ? v : path;
}

// Slug segmentu „transfery korporacyjne" zależnie od locale.
// Wszystkie 3 huby kierują w to samo miejsce (kanoniczny segment lotniskowy).
const corporateHref =
  locale === "pl" ? "/transfery-korporacyjne" : "/en/corporate-transfers";

// Slug strony „o nas" — link z bazy (Tarnowskie Góry).
const aboutHref = locale === "pl" ? "/o-nas" : "/en/about";

// Stałe IDs do aria-labelledby (unique per variant, gdyby kiedyś dwa
// atlasy były obok siebie — w 2026 nie są, ale dyscyplina).
const titleId = `atlas-title-${variant}`;
const leadId = `atlas-lead-${variant}`;
const liveRegionId = `atlas-live-${variant}`;
---

<section
  class:list={["vv-atlas", `vv-atlas--${variant}`]}
  aria-labelledby={titleId}
  data-atlas-variant={variant}
>
  {/* ───────── Header — title + lead ───────── */}
  <header class="vv-atlas__header vv-reveal">
    <h2 id={titleId} class="vv-atlas__title">
      {dict.atlas.title}
    </h2>
    <p id={leadId} class="vv-atlas__lead">
      {dict.atlas.lead}
    </p>
  </header>

  {/* ───────── Grid: SVG mapa + info panel ───────── */}
  <div class="vv-atlas__grid vv-reveal">
    {/* ── Lewa: SVG mapa (wymiar w viewBox 800×600 = 4:3) ── */}
    <figure class="vv-atlas__map-figure">
      <svg
        class="vv-atlas__svg"
        viewBox="0 0 800 600"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-labelledby={titleId}
        aria-describedby={leadId}
        preserveAspectRatio="xMidYMid meet"
      >
        <title>{dict.atlas.title}</title>

        {/* ── Województwa (warstwa 1, base) ── */}
        <g class="vv-atlas__regions" data-layer="regions">
          {
            regions.map((r) => (
              <g class="vv-atlas__region" data-region-id={r.id}>
                <path
                  class="vv-atlas__region-shape"
                  d={r.path}
                  role="button"
                  tabindex="0"
                  aria-label={`${tKey(r.nameKey)} — ${tKey(r.statKey)}`}
                  data-region-trigger
                />
                <text
                  class="vv-atlas__region-label"
                  x={r.labelX}
                  y={r.labelY}
                  text-anchor="middle"
                  aria-hidden="true"
                >
                  {tKey(r.nameKey)}
                </text>
              </g>
            ))
          }
        </g>

        {/* ── Trasy hub→base (warstwa 2, nad regionami pod hubami) ── */}
        <g class="vv-atlas__routes" data-layer="routes" aria-hidden="true">
          {
            hubs.map((h) => (
              <path
                class="vv-atlas__route"
                data-route-for={h.id}
                d={routePathFromBaseToHub(h)}
                fill="none"
              />
            ))
          }
        </g>

        {/* ── Huby lotniskowe (warstwa 3) ── */}
        <g class="vv-atlas__hubs" data-layer="hubs">
          {
            hubs.map((h) => (
              <g class="vv-atlas__hub" data-hub-id={h.id}>
                {/* Większy hit-target tła (przezroczyste koło ≥44px) */}
                <circle
                  class="vv-atlas__hub-hit"
                  cx={h.cx}
                  cy={h.cy}
                  r="22"
                  role="button"
                  tabindex="0"
                  aria-label={`${h.aria}. ${dict.atlas.hub.ctaLabel}.`}
                  data-hub-trigger
                />
                {/* Biały rim (większe koło) */}
                <circle
                  class="vv-atlas__hub-rim"
                  cx={h.cx}
                  cy={h.cy}
                  r="10"
                  aria-hidden="true"
                />
                {/* Czerwony znacznik */}
                <circle
                  class="vv-atlas__hub-dot"
                  cx={h.cx}
                  cy={h.cy}
                  r="7"
                  aria-hidden="true"
                />
                {/* Label */}
                <text
                  class="vv-atlas__hub-label"
                  x={h.cx}
                  y={h.cy - 18}
                  text-anchor="middle"
                  aria-hidden="true"
                >
                  {h.displayName}
                </text>
              </g>
            ))
          }
        </g>

        {/* ── Baza Tarnowskie Góry (warstwa 4, najwyższa) ── */}
        <g class="vv-atlas__base" data-base-id="tarnowskie-gory">
          {/* Hit target */}
          <circle
            class="vv-atlas__base-hit"
            cx={baseLocation.cx}
            cy={baseLocation.cy}
            r="26"
            role="button"
            tabindex="0"
            aria-label={baseLocation.aria}
            data-base-trigger
          />
          {/* Biały rim */}
          <circle
            class="vv-atlas__base-rim"
            cx={baseLocation.cx}
            cy={baseLocation.cy}
            r="14"
            aria-hidden="true"
          />
          {/* Czarny core (kontrast z czerwonymi hubami) */}
          <circle
            class="vv-atlas__base-dot"
            cx={baseLocation.cx}
            cy={baseLocation.cy}
            r="10"
            aria-hidden="true"
          />
          {/* Label */}
          <text
            class="vv-atlas__base-label"
            x={baseLocation.cx}
            y={baseLocation.cy + 32}
            text-anchor="middle"
            aria-hidden="true"
          >
            {baseLocation.label}
          </text>
          <text
            class="vv-atlas__base-sublabel"
            x={baseLocation.cx}
            y={baseLocation.cy + 47}
            text-anchor="middle"
            aria-hidden="true"
          >
            · {dict.atlas.base.label} ·
          </text>
        </g>
      </svg>

      <figcaption class="vv-atlas__caption">
        {variant === "full" ? dict.atlas.captionFull : dict.atlas.captionCompact}
      </figcaption>
    </figure>

    {/* ── Prawa: info panel (variant="full") lub skip (variant="compact") ── */}
    {
      variant === "full" && (
        <aside
          class="vv-atlas__panel"
          aria-live="polite"
          aria-atomic="true"
          id={liveRegionId}
          data-atlas-panel
        >
          <div class="vv-atlas__panel-inner">
            {/* Default state — kategoria + tytuł + body */}
            <p class="vv-atlas__panel-kicker" data-panel-kicker>
              N°04
            </p>
            <h3 class="vv-atlas__panel-title" data-panel-title>
              {dict.atlas.defaultPanel.title}
            </h3>
            <p class="vv-atlas__panel-body" data-panel-body>
              {dict.atlas.defaultPanel.body}
            </p>

            {/* CTA — niewidoczne w default, pokazane gdy hub/base aktywny */}
            <a
              class="vv-atlas__panel-cta"
              href={corporateHref}
              data-panel-cta
              hidden
            >
              <span data-panel-cta-label>{dict.atlas.hub.ctaLabel}</span>
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>

          {/* Legend — zawsze widoczna, dyskretna pod panelem */}
          <dl class="vv-atlas__legend">
            <div class="vv-atlas__legend-item">
              <span class="vv-atlas__legend-swatch vv-atlas__legend-swatch--region" aria-hidden="true" />
              <dt>{dict.atlas.legend.region}</dt>
              <dd>4</dd>
            </div>
            <div class="vv-atlas__legend-item">
              <span class="vv-atlas__legend-swatch vv-atlas__legend-swatch--hub" aria-hidden="true" />
              <dt>{dict.atlas.legend.hub}</dt>
              <dd>3</dd>
            </div>
            <div class="vv-atlas__legend-item">
              <span class="vv-atlas__legend-swatch vv-atlas__legend-swatch--base" aria-hidden="true" />
              <dt>{dict.atlas.legend.base}</dt>
              <dd>1</dd>
            </div>
          </dl>
        </aside>
      )
    }

    {
      variant === "compact" && (
        <p
          class="vv-atlas__live-compact"
          aria-live="polite"
          id={liveRegionId}
        />
      )
    }
  </div>
</section>

{/* ──────────────────── Vanilla JS — interactivity ──────────────────── */}
<script
  is:inline
  define:vars={{
    variant,
    corporateHref,
    aboutHref,
    titleId,
    leadId,
    liveRegionId,
    regionData: regions.map((r) => ({
      id: r.id,
      name: tKey(r.nameKey),
      stat: tKey(r.statKey),
    })),
    hubData: hubs.map((h) => ({
      id: h.id,
      name: h.displayName,
      mins: h.distanceFromBaseMinutes,
      aria: h.aria,
    })),
    baseDataLabel: baseLocation.label,
    baseAddress: dict.atlas.base.address,
    defaultPanel: dict.atlas.defaultPanel,
    hubLabels: dict.atlas.hub,
    baseLabels: dict.atlas.base,
    legendRegion: dict.atlas.legend.region,
  }}
>
  (() => {
    // Każdy variant na stronie może wystąpić raz; szukamy po atrybucie.
    const sections = document.querySelectorAll(
      `.vv-atlas[data-atlas-variant="${variant}"]`,
    );
    if (sections.length === 0) return;

    // Reduced motion = nadal interaktywne (focus/click) ale bez fancy transitions.
    const reducedMotion =
      typeof window.matchMedia === "function" &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    sections.forEach((section) => {
      const svg = section.querySelector(".vv-atlas__svg");
      const panel = section.querySelector("[data-atlas-panel]");
      const liveCompact = section.querySelector(".vv-atlas__live-compact");
      const panelKicker = section.querySelector("[data-panel-kicker]");
      const panelTitle = section.querySelector("[data-panel-title]");
      const panelBody = section.querySelector("[data-panel-body]");
      const panelCta = section.querySelector("[data-panel-cta]");
      const panelCtaLabel = section.querySelector("[data-panel-cta-label]");

      // Trzymamy state — który element jest aktywny (potrzebne dla SR „goto same again")
      let activeKey = null;

      // ── Reset do default state ──
      function resetPanel() {
        if (panel) {
          if (panelKicker) panelKicker.textContent = "N°04";
          if (panelTitle) panelTitle.textContent = defaultPanel.title;
          if (panelBody) panelBody.textContent = defaultPanel.body;
          if (panelCta) panelCta.setAttribute("hidden", "");
        }
        if (liveCompact) liveCompact.textContent = "";
        // Reset wszystkie active states na SVG
        svg.querySelectorAll(".is-active").forEach((el) => {
          el.classList.remove("is-active");
        });
        activeKey = null;
      }

      // ── Update panel dla regionu ──
      function showRegion(regionId) {
        const data = regionData.find((r) => r.id === regionId);
        if (!data) return;
        activeKey = "region:" + regionId;

        // Update SVG active state
        svg.querySelectorAll(".is-active").forEach((el) => {
          el.classList.remove("is-active");
        });
        const target = svg.querySelector(
          `.vv-atlas__region[data-region-id="${regionId}"]`,
        );
        if (target) target.classList.add("is-active");

        if (panel) {
          if (panelKicker) panelKicker.textContent = legendRegion;
          if (panelTitle) panelTitle.textContent = data.name;
          if (panelBody) panelBody.textContent = data.stat;
          if (panelCta) panelCta.setAttribute("hidden", "");
        }
        if (liveCompact) {
          liveCompact.textContent = data.name + ": " + data.stat;
        }
      }

      // ── Update panel dla huba ──
      function showHub(hubId) {
        const data = hubData.find((h) => h.id === hubId);
        if (!data) return;
        activeKey = "hub:" + hubId;

        svg.querySelectorAll(".is-active").forEach((el) => {
          el.classList.remove("is-active");
        });
        const target = svg.querySelector(
          `.vv-atlas__hub[data-hub-id="${hubId}"]`,
        );
        if (target) target.classList.add("is-active");
        const route = svg.querySelector(`.vv-atlas__route[data-route-for="${hubId}"]`);
        if (route) route.classList.add("is-active");

        if (panel) {
          if (panelKicker) panelKicker.textContent = hubLabels.label;
          if (panelTitle) panelTitle.textContent = data.name;
          if (panelBody)
            panelBody.textContent =
              hubLabels.distanceLabel + ": " + data.mins + " " + hubLabels.minutes + ".";
          if (panelCta) {
            panelCta.removeAttribute("hidden");
            panelCta.setAttribute("href", corporateHref);
            if (panelCtaLabel) panelCtaLabel.textContent = hubLabels.ctaLabel;
          }
        }
        if (liveCompact) {
          liveCompact.textContent =
            data.name + " — " + data.mins + " " + hubLabels.minutes;
        }
      }

      // ── Update panel dla bazy ──
      function showBase() {
        activeKey = "base";

        svg.querySelectorAll(".is-active").forEach((el) => {
          el.classList.remove("is-active");
        });
        const target = svg.querySelector(".vv-atlas__base");
        if (target) target.classList.add("is-active");

        if (panel) {
          if (panelKicker) panelKicker.textContent = baseLabels.label;
          if (panelTitle) panelTitle.textContent = baseDataLabel;
          if (panelBody) panelBody.textContent = baseAddress;
          if (panelCta) {
            panelCta.removeAttribute("hidden");
            panelCta.setAttribute("href", aboutHref);
            if (panelCtaLabel) panelCtaLabel.textContent = baseLabels.cta;
          }
        }
        if (liveCompact) {
          liveCompact.textContent = baseDataLabel + " — " + baseAddress;
        }
      }

      // ── Bindings: regions ──
      svg.querySelectorAll("[data-region-trigger]").forEach((el) => {
        const regionId = el.closest(".vv-atlas__region")?.dataset.regionId;
        if (!regionId) return;
        el.addEventListener("pointerenter", () => showRegion(regionId));
        el.addEventListener("focus", () => showRegion(regionId));
        // Spacja/Enter — w SVG <path role=button> nie reagują natywnie,
        // bindujemy ręcznie. Brak click navigation dla region (to nie CTA).
        el.addEventListener("keydown", (e) => {
          if (e.key === " " || e.key === "Enter") {
            e.preventDefault();
            showRegion(regionId);
          }
        });
      });

      // ── Bindings: hubs ──
      svg.querySelectorAll("[data-hub-trigger]").forEach((el) => {
        const hubId = el.closest(".vv-atlas__hub")?.dataset.hubId;
        if (!hubId) return;
        el.addEventListener("pointerenter", () => showHub(hubId));
        el.addEventListener("focus", () => showHub(hubId));
        // Klik na hubie = nawigacja do segmentu (canonical CTA huba)
        el.addEventListener("click", (e) => {
          e.preventDefault();
          window.location.href = corporateHref;
        });
        el.addEventListener("keydown", (e) => {
          if (e.key === " " || e.key === "Enter") {
            e.preventDefault();
            // Pierwsze trafienie focusem = pokazujemy panel; powtórny Enter = nawigacja
            if (activeKey === "hub:" + hubId) {
              window.location.href = corporateHref;
            } else {
              showHub(hubId);
            }
          }
        });
      });

      // ── Bindings: base ──
      const baseTrigger = svg.querySelector("[data-base-trigger]");
      if (baseTrigger) {
        baseTrigger.addEventListener("pointerenter", showBase);
        baseTrigger.addEventListener("focus", showBase);
        baseTrigger.addEventListener("click", (e) => {
          e.preventDefault();
          // Variant "full" = scroll do #dla-kogo (już jesteśmy na home);
          // variant "compact" = już na /o-nas, nic nie robimy (po prostu pokaż panel)
          if (variant === "full") {
            const target = document.getElementById("dla-kogo");
            if (target) {
              target.scrollIntoView({
                behavior: reducedMotion ? "auto" : "smooth",
                block: "start",
              });
            }
          }
        });
        baseTrigger.addEventListener("keydown", (e) => {
          if (e.key === " " || e.key === "Enter") {
            e.preventDefault();
            if (activeKey === "base") {
              // Powtórny Enter = nawigacja do /o-nas
              window.location.href = aboutHref;
            } else {
              showBase();
            }
          }
        });
      }

      // ── Reset gdy mysz opuści całe SVG (rozsądny UX, panel wraca do default) ──
      svg.addEventListener("pointerleave", () => {
        // Tylko jeśli nic nie ma focusa wewnątrz (klawiatura ma priorytet)
        const focused = svg.querySelector(":focus");
        if (!focused) resetPanel();
      });

      // ── Initial state — nothing active, panel = default ──
      resetPanel();
    });
  })();
</script>

<style>
  /* ───────────────────── Section wrapper ───────────────────── */
  .vv-atlas {
    /* Sekcja używa „surface" base background dla kontrastu vs sąsiedzkie tony.
       Na home: po SegmentGrid (elevated) → atlas (surface) → flota (default).
       Na /o-nas: w sekcji „Gdzie jeździmy" (default) → embedded compact. */
    background-color: var(--vv-color-bg-surface);
    padding-block: var(--vv-space-16);
  }

  .vv-atlas--full {
    padding-block: var(--vv-space-20);
  }

  .vv-atlas--compact {
    background-color: transparent;
    padding-block: 0;
  }

  /* Kontener wewnętrzny — używamy klasy `.container` z utilities.css
     przez bezpośredni padding-inline. Sekcja jest osadzona w Container
     dla wariantu compact (w /o-nas), więc tu nie wraapujemy ponownie;
     dla wariantu full robimy własny padding. */
  .vv-atlas--full {
    padding-inline: var(--vv-space-5);
  }

  @media (min-width: 768px) {
    .vv-atlas--full {
      padding-inline: var(--vv-space-8);
    }
  }

  /* ───────────────────── Header ───────────────────── */
  .vv-atlas__header {
    max-width: 64ch;
    margin: 0 auto var(--vv-space-10) auto;
  }

  .vv-atlas--full .vv-atlas__header {
    margin-inline: 0;
    max-width: 70ch;
  }

  .vv-atlas__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: clamp(1.75rem, 4vw, var(--vv-typography-font-size-4xl));
    font-weight: var(--vv-typography-font-weight-extrabold);
    line-height: var(--vv-typography-line-height-tight);
    letter-spacing: var(--vv-typography-letter-spacing-tight);
    color: var(--vv-color-fg-primary);
    margin: 0 0 var(--vv-space-4) 0;
    text-wrap: balance;
  }

  .vv-atlas__lead {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    text-wrap: pretty;
  }

  /* ───────────────────── Grid: mapa + panel ───────────────────── */
  .vv-atlas__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-8);
    align-items: start;
    max-width: 1200px;
  }

  .vv-atlas--full .vv-atlas__grid {
    margin-inline: 0;
  }

  @media (min-width: 1024px) {
    .vv-atlas--full .vv-atlas__grid {
      grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
      gap: var(--vv-space-10);
    }
  }

  /* ───────────────────── Figure / map ───────────────────── */
  .vv-atlas__map-figure {
    margin: 0;
    background-color: var(--vv-color-bg-page);
    border: 1px solid var(--vv-color-border-subtle);
    border-radius: var(--vv-radius-xl);
    padding: var(--vv-space-5);
    display: flex;
    flex-direction: column;
    gap: var(--vv-space-4);
  }

  .vv-atlas--compact .vv-atlas__map-figure {
    background-color: var(--vv-color-bg-elevated);
    padding: var(--vv-space-6);
  }

  .vv-atlas__svg {
    width: 100%;
    height: auto;
    display: block;
    /* Zapobiega zaznaczaniu tekstu wewnątrz SVG przy szybkim klikaniu */
    user-select: none;
  }

  .vv-atlas__caption {
    font-size: var(--vv-typography-font-size-sm);
    color: var(--vv-color-fg-muted);
    line-height: var(--vv-typography-line-height-relaxed);
    margin: 0;
    text-align: center;
  }

  /* ───────────────────── Regiony (SVG) ─────────────────────
   *
   * Domyślnie: subtelny brand-red wash (4% alpha) + 1.5px stroke (25% alpha).
   * Hover/focus/is-active: stroke staje się solid brand-red, fill → 8% alpha,
   * cursor: pointer.
   *
   * vector-effect: non-scaling-stroke — stroke zachowuje 1.5px niezależnie
   * od skali viewportu. Bez tego stroke pęcznieje na małych ekranach.
