---
/**
 * AtlasPoludnia — „Carta Operacyjna" editorial atlas (Wow #1).
 *
 * Pełny rewrite v2 (2026-06-01). Mapa południowej Polski oparta o realne
 * dane geodezyjne GUGiK (ppatrzyk/polska-geojson, MIT) przeprojektowane na
 * EPSG:2180 (PUWG 1992) w build step (`scripts/build-atlas.mjs`).
 *
 * Warstwy SVG (kolejność rysowania):
 *   1. Ghost regions — 12 województw spoza rdzenia, subtelny kontur 0.4px,
 *      base map context "to jest południowa Polska".
 *   2. Core regions — 4 województwa rdzeniowe (śląskie, opolskie,
 *      małopolskie, świętokrzyskie). Wash red 4% + 1px stroke. Hoverable.
 *   3. Routes — proste linie baza → 3 huby. Hidden default, drawn-once
 *      przy hover/focus huba (data-active="true").
 *   4. Saint markers — 4 sanktuaria w rdzeniu (Częstochowa, Kalwaria,
 *      Łagiewniki, Wadowice). Mono labels.
 *   5. Off-view saint arrows — Licheń + Niepokalanów na N edge,
 *      adnotacja kierunkowa "Licheń ↗ 200 km".
 *   6. Hub markers — 3 lotniska. Red rim + white core. Większy hit target.
 *   7. Base marker — Tarnowskie Góry. Czarny kwadrat (kontrast vs okrągłe
 *      huby), 2-linijkowy label.
 *   8. Compass + scale bar — editorial cartography signal.
 *
 * Variants:
 *   - "full"    = home page; mapa + side panel z N°04 indeks + statystyki.
 *   - "compact" = /o-nas; sama mapa, panel zwijany do single-line.
 *
 * A11y:
 *   - SVG <title> + <desc> jako pierwsze dzieci.
 *   - Regions/hubs/base = tabindex="0" role="button" z aria-label.
 *   - aria-live region pod mapą — anonsuje hover-state.
 *   - prefers-reduced-motion: brak transitions, instant final state.
 *
 * Perf:
 *   - JS overhead ~1.8 KB raw (no deps, no rAF, no throttling).
 *   - Inline SVG, zero zewnętrznych assetów, SSR-stable.
 *   - Mapa renderuje statycznie — JS jest progressive enhancement.
 */

import {
  regions,
  ghostRegions,
  points,
  SVG_W,
  SVG_H,
  type AtlasPoint,
} from "@data/atlas/atlas.generated";
import { getDictionary, type Locale } from "@i18n/index";
import SectionIndex from "@components/ui/SectionIndex.astro";

interface Props {
  locale: Locale;
  /** Wariant kompozycji: "full" (home) lub "compact" (/o-nas). */
  variant?: "full" | "compact";
}

const { locale, variant = "full" } = Astro.props;
const dict = getDictionary(locale);

// i18n region name fallback — jeśli klucz nie istnieje (np. dla GHOST), wraca name.
function regionDisplayName(id: string, fallback: string): string {
  const key = id as keyof typeof dict.atlas.region;
  const v = dict.atlas.region[key];
  return typeof v === "string" ? v : fallback;
}

function regionStat(id: string): string {
  const key = id as keyof typeof dict.atlas.stat;
  const v = dict.atlas.stat[key];
  return typeof v === "string" ? v : "";
}

// Slugi segmentów dla CTA — huby zawsze prowadzą do transferów korpo.
const corporateHref =
  locale === "pl" ? "/transfery-korporacyjne" : "/en/corporate-transfers";
const aboutHref = locale === "pl" ? "/o-nas" : "/en/about";

// Identifikatory dla aria-labelledby (unique per variant).
const titleId = `atlas-title-${variant}`;
const descId = `atlas-desc-${variant}`;
const leadId = `atlas-lead-${variant}`;
const liveRegionId = `atlas-live-${variant}`;

// Punkty na mapie — typed access dla TS safety.
const hubKeys = ["hubPyrzowice", "hubBalice", "hubWroclaw"] as const;
const baseKey = "baseTG";
const saintsInViewKeys = [
  "saintCzestochowa",
  "saintKalwaria",
  "saintLagiewniki",
  "saintWadowice",
] as const;
const saintsOffViewKeys = ["saintLichen", "saintNiepokalanow"] as const;

const base: AtlasPoint = points[baseKey];

// Label offsets dla sanktuariów — dla Łagiewniki/Wadowice (bliskie Kalwarii)
// i wszystkich w okolicy huba Balice trzeba ręcznie odsunąć label żeby nie
// nachodziły z hub-time "90 min" (svgY = hub.svgY + 22).
const saintLabelOffsets: Record<string, { dx: number; dy: number; anchor: string }> = {
  saintCzestochowa: { dx: 6, dy: 3, anchor: "start" },
  saintKalwaria: { dx: 6, dy: 11, anchor: "start" },  // pod kropką, E (start)
  saintLagiewniki: { dx: 7, dy: 3, anchor: "start" }, // E od kropki (Łagiewniki to dzielnica Krakowa — natural E expansion, omijamy 90 MIN po W)
  saintWadowice: { dx: -7, dy: 3, anchor: "end" },    // W od kropki (Wadowice)
};

// Statystyki sekcji — wyświetlane w side panel.
const stats = [
  { dt: dict.atlas.legend.region, dd: "4" },
  { dt: dict.atlas.legend.hub, dd: "3" },
  { dt: dict.atlas.legend.base, dd: "1" },
];

// Kicker / mark — editorial map header.
const kickerText = locale === "pl" ? "Mapa N°01 · Południe Polski" : "Map N°01 · Southern Poland";
const captionSource =
  locale === "pl"
    ? "Źródło GUGiK · projekcja PUWG 1992 (EPSG:2180) · uproszczenie 250 m"
    : "Source GUGiK · projection PUWG 1992 (EPSG:2180) · simplification 250 m";
const compassLabel = "N";
const scaleLabel = "50 km";

// Skala kilometrowa — przeliczamy 50 km na pixele przy aktualnym scale.
// Z build script: scale = 0.001663 px/m → 50 km = 50000 m = 83.16 px.
// Hardcoded bo scale jest stały dla obecnego viewBox + bbox (regenerowane build-time).
const SCALE_50KM_PX = 83.16;

// Off-view sanctuary annotations — kierunek + szacunkowa odległość drogowa.
// Punkty oryginalnie na N/NE od rdzenia, więc obie strzałki na top edge SVG.
const offViewAnnotations: Record<string, { distanceKm: number; bearing: string }> = {
  saintLichen: { distanceKm: 200, bearing: "↑" },
  saintNiepokalanow: { distanceKm: 245, bearing: "↗" },
};
---

<section
  class:list={["vv-atlas", `vv-atlas--${variant}`]}
  aria-labelledby={titleId}
  data-atlas-variant={variant}
>
  <div class="vv-atlas__container">
    {/* ───────── Header — kicker + title + lead ───────── */}
    <header class="vv-atlas__header vv-reveal">
      <p class="vv-atlas__kicker">{kickerText}</p>
      <h2 id={titleId} class="vv-atlas__title">
        {dict.atlas.title}
      </h2>
      <p id={leadId} class="vv-atlas__lead">
        {dict.atlas.lead}
      </p>
    </header>

    {/* ───────── Grid: figure + side panel ───────── */}
    <div class="vv-atlas__grid vv-reveal">
      <figure class="vv-atlas__figure" aria-describedby={descId}>
        <svg
          class="vv-atlas__svg"
          viewBox={`0 0 ${SVG_W} ${SVG_H}`}
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-labelledby={titleId}
          preserveAspectRatio="xMidYMid meet"
        >
          <title>{dict.atlas.title}</title>
          <desc id={descId}>{dict.atlas.lead}</desc>

          {/* ── Layer 1: Ghost regions (reszta PL — base map context) ── */}
          <g class="vv-atlas__ghost" aria-hidden="true">
            {
              ghostRegions.map((r) => (
                <path
                  d={r.d}
                  class="vv-atlas__ghost-region"
                  data-ghost-id={r.id}
                />
              ))
            }
          </g>

          {/* ── Layer 2: Core regions (4 woj. rdzeniowe) ── */}
          <g class="vv-atlas__regions" data-layer="regions">
            {
              regions.map((r) => (
                <g class="vv-atlas__region" data-region-id={r.id}>
                  <path
                    d={r.d}
                    class="vv-atlas__region-shape"
                    role="button"
                    tabindex="0"
                    aria-label={`${regionDisplayName(r.id, r.name)} — ${regionStat(r.id)}`}
                    data-region-trigger
                  />
                </g>
              ))
            }
          </g>

          {/* ── Layer 3: Routes (baza → 3 huby, hidden by default) ── */}
          <g class="vv-atlas__routes" data-layer="routes" aria-hidden="true">
            {
              hubKeys.map((key) => {
                const hub = points[key];
                return (
                  <path
                    class="vv-atlas__route"
                    data-route-to={key}
                    d={`M ${base.svgX} ${base.svgY} L ${hub.svgX} ${hub.svgY}`}
                    fill="none"
                  />
                );
              })
            }
          </g>

          {/* ── Layer 4: Saint markers (in-view, 4 sanktuaria) ── */}
          <g class="vv-atlas__saints" data-layer="saints">
            {
              saintsInViewKeys.map((key) => {
                const p = points[key];
                if (!p.inView) return null;
                const off = saintLabelOffsets[key];
                return (
                  <g class="vv-atlas__saint" data-saint-id={key}>
                    <circle
                      cx={p.svgX}
                      cy={p.svgY}
                      r="2.5"
                      class="vv-atlas__saint-dot"
                    />
                    <text
                      x={p.svgX + off.dx}
                      y={p.svgY + off.dy}
                      class="vv-atlas__saint-label"
                      text-anchor={off.anchor}
                    >
                      {p.label}
                    </text>
                  </g>
                );
              })
            }
          </g>

          {/* ── Layer 5: Off-view saint arrows (Licheń, Niepokalanów na N) ── */}
          <g class="vv-atlas__saints-offview" data-layer="saints-off" aria-hidden="true">
            {
              saintsOffViewKeys.map((key, idx) => {
                const p = points[key];
                const ann = offViewAnnotations[key];
                // Klampujemy svgX do viewport zakresu z marginesem 60px.
                const arrowX = Math.max(60, Math.min(SVG_W - 60, p.svgX));
                const arrowY = 18; // edge of viewport
                return (
                  <g
                    class="vv-atlas__saint-offview"
                    data-saint-off-id={key}
                    transform={`translate(${arrowX}, ${arrowY})`}
                  >
                    <text class="vv-atlas__saint-off-bearing" text-anchor="middle" y="0">
                      {ann.bearing}
                    </text>
                    <text class="vv-atlas__saint-off-label" text-anchor="middle" y="14">
                      {p.label} · {ann.distanceKm} km
                    </text>
                  </g>
                );
              })
            }
          </g>

          {/* ── Layer 6: Hub markers (3 lotniska) ── */}
          <g class="vv-atlas__hubs" data-layer="hubs">
            {
              hubKeys.map((key) => {
                const p = points[key];
                return (
                  <g class="vv-atlas__hub" data-hub-id={key}>
                    {/* Hit target (≥ 44px) */}
                    <circle
                      cx={p.svgX}
                      cy={p.svgY}
                      r="22"
                      class="vv-atlas__hub-hit"
                      role="button"
                      tabindex="0"
                      aria-label={`${dict.atlas.hub.label} ${p.label} — ${p.time} ${dict.atlas.hub.minutes}`}
                      data-hub-trigger
                    />
                    {/* Rim (white) */}
                    <circle
                      cx={p.svgX}
                      cy={p.svgY}
                      r="7"
                      class="vv-atlas__hub-rim"
                      aria-hidden="true"
                    />
                    {/* Dot (brand red) */}
                    <circle
                      cx={p.svgX}
                      cy={p.svgY}
                      r="4"
                      class="vv-atlas__hub-dot"
                      aria-hidden="true"
                    />
                    {/* Label + time STACK nad hubem (label wyżej, time tuż pod).
                        Większy odstęp od kropki (22px) bo Pyrzowice sąsiadują
                        z bazą TG — chcemy jasną separację typograficzną. */}
                    <text
                      x={p.svgX}
                      y={p.svgY - 22}
                      class="vv-atlas__hub-label"
                      text-anchor="middle"
                      aria-hidden="true"
                    >
                      {p.label.toUpperCase()}
                    </text>
                    <text
                      x={p.svgX}
                      y={p.svgY - 12}
                      class="vv-atlas__hub-time"
                      text-anchor="middle"
                      aria-hidden="true"
                    >
                      {p.time} {dict.atlas.hub.minutes}
                    </text>
                  </g>
                );
              })
            }
          </g>

          {/* ── Layer 7: Base marker (Tarnowskie Góry) ── */}
          <g class="vv-atlas__base" data-base-id="tarnowskie-gory">
            {/* Hit target */}
            <circle
              cx={base.svgX}
              cy={base.svgY}
              r="22"
              class="vv-atlas__base-hit"
              role="button"
              tabindex="0"
              aria-label={dict.atlas.base.address}
              data-base-trigger
            />
            {/* Kwadrat (kontrast vs okrągłe huby — baza jest „inna") */}
            <rect
              x={base.svgX - 5.5}
              y={base.svgY - 5.5}
              width="11"
              height="11"
              class="vv-atlas__base-square"
              aria-hidden="true"
            />
            <rect
              x={base.svgX - 2.5}
              y={base.svgY - 2.5}
              width="5"
              height="5"
              class="vv-atlas__base-core"
              aria-hidden="true"
            />
            {/* Label 2-linijkowy — przesunięty na W od bazy żeby nie nachodzić
                z hub-time pod Pyrzowicami (które są na E+N od bazy). */}
            <text
              x={base.svgX - 14}
              y={base.svgY + 4}
              class="vv-atlas__base-label"
              text-anchor="end"
              aria-hidden="true"
            >
              {base.label}
            </text>
            <text
              x={base.svgX - 14}
              y={base.svgY + 15}
              class="vv-atlas__base-sublabel"
              text-anchor="end"
              aria-hidden="true"
            >
              · {dict.atlas.base.label.toUpperCase()} ·
            </text>
          </g>

          {/* ── Layer 8: Compass (top-right) ── */}
          <g
            class="vv-atlas__compass"
            aria-hidden="true"
            transform={`translate(${SVG_W - 42}, 36)`}
          >
            <text class="vv-atlas__compass-label" text-anchor="middle" y="0">
              {compassLabel}
            </text>
            <line x1="0" y1="6" x2="0" y2="22" class="vv-atlas__compass-line" />
            <polygon
              points="0,6 -3.5,14 3.5,14"
              class="vv-atlas__compass-arrow"
            />
          </g>

          {/* ── Layer 9: Scale bar (bottom-right) ── */}
          <g
            class="vv-atlas__scale"
            aria-hidden="true"
            transform={`translate(${SVG_W - 120}, ${SVG_H - 24})`}
          >
            <line
              x1="0"
              y1="0"
              x2={SCALE_50KM_PX}
              y2="0"
              class="vv-atlas__scale-line"
            />
            <line
              x1="0"
              y1="-4"
              x2="0"
              y2="4"
              class="vv-atlas__scale-tick"
            />
            <line
              x1={SCALE_50KM_PX}
              y1="-4"
              x2={SCALE_50KM_PX}
              y2="4"
              class="vv-atlas__scale-tick"
            />
            <text
              x={SCALE_50KM_PX / 2}
              y="-7"
              class="vv-atlas__scale-label"
              text-anchor="middle"
            >
              {scaleLabel}
            </text>
          </g>
        </svg>

        <figcaption class="vv-atlas__caption">{captionSource}</figcaption>
      </figure>

      {/* ── Side panel (variant=full only) ── */}
      {
        variant === "full" && (
          <aside
            class="vv-atlas__panel"
            aria-live="polite"
            aria-atomic="true"
            id={liveRegionId}
            data-atlas-panel
          >
            <SectionIndex number={4} label={dict.atlas.hub.label} />

            <h3 class="vv-atlas__panel-title" data-panel-title>
              {dict.atlas.defaultPanel.title}
            </h3>
            <p class="vv-atlas__panel-body" data-panel-body>
              {dict.atlas.defaultPanel.body}
            </p>

            <a
              class="vv-atlas__panel-cta"
              href={corporateHref}
              data-panel-cta
              hidden
            >
              <span data-panel-cta-label>{dict.atlas.hub.ctaLabel}</span>
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>

            <dl class="vv-atlas__stats">
              {stats.map((s) => (
                <div class="vv-atlas__stats-row">
                  <dt>{s.dt}</dt>
                  <dd>{s.dd}</dd>
                </div>
              ))}
            </dl>
          </aside>
        )
      }

      {/* ── Live-only region (variant=compact) ── */}
      {
        variant === "compact" && (
          <p
            class="vv-atlas__live-compact"
            aria-live="polite"
            id={liveRegionId}
          />
        )
      }
    </div>
  </div>
</section>

{/* ───────────────── Vanilla JS — interactivity ───────────────── */}
<script
  is:inline
  define:vars={{
    variant,
    corporateHref,
    aboutHref,
    liveRegionId,
    regionData: regions.map((r) => ({
      id: r.id,
      name: regionDisplayName(r.id, r.name),
      stat: regionStat(r.id),
    })),
    hubData: hubKeys.map((key) => ({
      id: key,
      label: points[key].label,
      time: points[key].time ?? 0,
    })),
    baseAddress: dict.atlas.base.address,
    baseLabel: base.label,
    baseFullLabel: dict.atlas.base.label,
    defaultPanel: dict.atlas.defaultPanel,
    hubLabels: dict.atlas.hub,
  }}
>
  (() => {
    const sections = document.querySelectorAll(
      `.vv-atlas[data-atlas-variant="${variant}"]`
    );
    if (sections.length === 0) return;

    sections.forEach((section) => {
      const panel = section.querySelector("[data-atlas-panel]");
      const liveCompact = section.querySelector(".vv-atlas__live-compact");
      const panelTitle = section.querySelector("[data-panel-title]");
      const panelBody = section.querySelector("[data-panel-body]");
      const panelCta = section.querySelector("[data-panel-cta]");
      const panelCtaLabel = section.querySelector("[data-panel-cta-label]");

      let activeKey = null;
      let resetTimer = null;

      function clearResetTimer() {
        if (resetTimer !== null) {
          window.clearTimeout(resetTimer);
          resetTimer = null;
        }
      }

      function resetPanel() {
        clearResetTimer();
        activeKey = null;
        if (panelTitle) panelTitle.textContent = defaultPanel.title;
        if (panelBody) panelBody.textContent = defaultPanel.body;
        if (panelCta) {
          panelCta.setAttribute("hidden", "");
          panelCta.setAttribute("href", corporateHref);
        }
        if (liveCompact) liveCompact.textContent = "";
        // De-activate all routes/regions/hubs
        section
          .querySelectorAll("[data-route-to]")
          .forEach((r) => r.removeAttribute("data-active"));
        section
          .querySelectorAll(".vv-atlas__region")
          .forEach((r) => r.classList.remove("is-active"));
        section
          .querySelectorAll(".vv-atlas__hub")
          .forEach((r) => r.classList.remove("is-active"));
        section
          .querySelector(".vv-atlas__base")
          ?.classList.remove("is-active");
      }

      function applyRegion(id) {
        const r = regionData.find((x) => x.id === id);
        if (!r) return;
        activeKey = `region:${id}`;
        if (panelTitle) panelTitle.textContent = r.name;
        if (panelBody) panelBody.textContent = r.stat;
        if (panelCta) panelCta.setAttribute("hidden", "");
        if (liveCompact) liveCompact.textContent = `${r.name} — ${r.stat}`;
        section
          .querySelectorAll(".vv-atlas__region")
          .forEach((el) => {
            const isMatch = el.dataset.regionId === id;
            el.classList.toggle("is-active", isMatch);
          });
      }

      function applyHub(id) {
        const h = hubData.find((x) => x.id === id);
        if (!h) return;
        activeKey = `hub:${id}`;
        if (panelTitle) {
          panelTitle.textContent = `${hubLabels.label} ${h.label}`;
        }
        if (panelBody) {
          panelBody.textContent = `${hubLabels.distanceLabel}: ${h.time} ${hubLabels.minutes}.`;
        }
        if (panelCta) {
          panelCta.removeAttribute("hidden");
          panelCta.setAttribute("href", corporateHref);
          if (panelCtaLabel) panelCtaLabel.textContent = hubLabels.ctaLabel;
        }
        if (liveCompact)
          liveCompact.textContent = `${hubLabels.label} ${h.label} — ${h.time} ${hubLabels.minutes}.`;

        section
          .querySelectorAll("[data-route-to]")
          .forEach((r) => {
            if (r.dataset.routeTo === id) {
              r.setAttribute("data-active", "true");
            } else {
              r.removeAttribute("data-active");
            }
          });
        section
          .querySelectorAll(".vv-atlas__hub")
          .forEach((el) => {
            const isMatch = el.dataset.hubId === id;
            el.classList.toggle("is-active", isMatch);
          });
      }

      function applyBase() {
        activeKey = "base";
        if (panelTitle) panelTitle.textContent = baseFullLabel;
        if (panelBody) panelBody.textContent = baseAddress;
        if (panelCta) {
          panelCta.removeAttribute("hidden");
          panelCta.setAttribute("href", aboutHref);
          if (panelCtaLabel) panelCtaLabel.textContent = baseFullLabel;
        }
        if (liveCompact) liveCompact.textContent = `${baseFullLabel} — ${baseAddress}`;
        section
          .querySelector(".vv-atlas__base")
          ?.classList.add("is-active");
      }

      function scheduleReset(delay = 2400) {
        clearResetTimer();
        resetTimer = window.setTimeout(() => resetPanel(), delay);
      }

      // ── Wire region triggers ──
      section
        .querySelectorAll("[data-region-trigger]")
        .forEach((trigger) => {
          const id = trigger.closest("[data-region-id]")?.dataset.regionId;
          if (!id) return;

          trigger.addEventListener("pointerenter", () => {
            clearResetTimer();
            applyRegion(id);
          });
          trigger.addEventListener("focusin", () => {
            clearResetTimer();
            applyRegion(id);
          });
          trigger.addEventListener("pointerleave", () => scheduleReset());
          trigger.addEventListener("focusout", () => scheduleReset());
        });

      // ── Wire hub triggers ──
      section
        .querySelectorAll("[data-hub-trigger]")
        .forEach((trigger) => {
          const id = trigger.closest("[data-hub-id]")?.dataset.hubId;
          if (!id) return;

          trigger.addEventListener("pointerenter", () => {
            clearResetTimer();
            applyHub(id);
          });
          trigger.addEventListener("focusin", () => {
            clearResetTimer();
            applyHub(id);
          });
          trigger.addEventListener("pointerleave", () => scheduleReset());
          trigger.addEventListener("focusout", () => scheduleReset());

          // Touch / click → nawigujemy do CTA
          trigger.addEventListener("click", () => {
            window.location.href = corporateHref;
          });
          trigger.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              window.location.href = corporateHref;
            }
          });
        });

      // ── Wire base trigger ──
      section
        .querySelectorAll("[data-base-trigger]")
        .forEach((trigger) => {
          trigger.addEventListener("pointerenter", () => {
            clearResetTimer();
            applyBase();
          });
          trigger.addEventListener("focusin", () => {
            clearResetTimer();
            applyBase();
          });
          trigger.addEventListener("pointerleave", () => scheduleReset());
          trigger.addEventListener("focusout", () => scheduleReset());

          trigger.addEventListener("click", () => {
            window.location.href = aboutHref;
          });
          trigger.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              window.location.href = aboutHref;
            }
          });
        });
    });
  })();
</script>

<style>
