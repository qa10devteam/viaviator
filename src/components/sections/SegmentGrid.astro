---
/**
 * SegmentGrid — grid 6 segmentów (P1-P6).
 * Każda karta: kolor accent z segment.color, nazwa, shortDesc, time-to-quote badge,
 * link do /{slug} (PL) lub /en/{slugEn}.
 *
 * Wymaga `segments` + `getDictionary(locale)` — wszystko z @data + @i18n.
 */

import { segments } from "@data/segments";
import { getDictionary, type Locale } from "@i18n/index";
import Card from "@components/ui/Card.astro";
import Badge from "@components/ui/Badge.astro";
import Icon from "@components/ui/Icon.astro";
import type { IconName } from "@components/ui/Icon.astro";

interface Props {
  locale: Locale;
  /** Pokaż wszystkie 6, czy filtruj */
  filterPersonaIds?: ("P1" | "P2" | "P3" | "P4" | "P5" | "P6")[];
  class?: string;
}

const { locale, filterPersonaIds, class: extraClass = "" } = Astro.props;
const dict = getDictionary(locale);

const items = filterPersonaIds
  ? segments.filter((s) => filterPersonaIds.includes(s.personaId))
  : segments;

function tKey(path: string): string {
  const v = path
    .split(".")
    .reduce<unknown>(
      (acc, k) =>
        acc && typeof acc === "object"
          ? (acc as Record<string, unknown>)[k]
          : undefined,
      dict,
    );
  return typeof v === "string" ? v : path;
}

// Mapa iconKeyword → IconName (z Icon.astro)
const ICON_MAP: Record<string, IconName> = {
  "briefcase-airport": "briefcase",
  "candle-route": "church",
  "wheelchair-care": "wheelchair",
  "family-suitcase": "users",
  "key-van": "key",
  "tent-popcorn": "tent",
};

// CTA label — z słownika cta (PL: „Dowiedz się więcej", EN: „Learn more")
const learnMore = dict.cta.learnMore;
---

<ul class:list={["vv-segments", extraClass]} role="list" data-reveal-cascade>
  {
    items.map((seg) => {
      const href = locale === "pl" ? `/${seg.slug}` : `/en/${seg.slugEn}`;
      const name = tKey(seg.nameKey);
      const shortDesc = tKey(seg.shortDescKey);
      const iconName = ICON_MAP[seg.iconKeyword];
      // M02: nazwa view-transition oparta o PL slug (kanoniczny w danych).
      // Per locale ten sam shared element identifier, bo card → hero
      // jest zawsze w obrębie tego samego języka, a Astro view-transition
      // matchuje tylko obecność tej samej nazwy w next document.
      const vtName = `segment-${seg.slug}`;

      return (
        <li class="vv-reveal">
          <Card
            href={href}
            interactive
            magnetic
            tone="default"
            accentColor={seg.color}
            class="vv-segments__card vv-segment-card"
            ariaLabel={`${name} — ${shortDesc}`}
            style={`view-transition-name: ${vtName};`}
          >
            {/* M05: flood layer (radial-gradient w accent color), positioned
                via --vv-card-mx/my CSS vars updated z JS na pointer:fine,
                fallback do plain hover na touch. aria-hidden bo to ornament. */}
            <div class="vv-segment-card__flood" aria-hidden="true"></div>

            <div class="vv-segments__head">
              {iconName && (
                <span
                  class="vv-segments__icon"
                  style={`--vv-seg-color:${seg.color}`}
                  aria-hidden="true"
                >
                  <Icon name={iconName} size={24} />
                </span>
              )}
              <Badge size="sm" tone="default" accentColor={seg.color}>
                <Icon name="clock" size={12} />
                <span>{seg.timeToQuote}</span>
              </Badge>
            </div>

            <h3 class="vv-segments__title">{name}</h3>
            <p class="vv-segments__desc">{shortDesc}</p>

            <span
              class="vv-segments__cta"
              style={`--vv-seg-color:${seg.color}`}
            >
              <span>{learnMore}</span>
              <Icon name="arrow-right" size={16} />
            </span>
          </Card>
        </li>
      );
    })
  }
</ul>

<style>
  .vv-segments {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--vv-space-5);
    margin: 0;
    padding: 0;
    /* M05: perspective ustawiony na grid container, nie na każdej karcie,
       żeby tilt każdej karty respektował jeden viewpoint (spójny parallax). */
    perspective: 1200px;
  }

  @media (min-width: 640px) {
    .vv-segments {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .vv-segments {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .vv-segments__card {
    height: 100%;
    gap: var(--vv-space-3);
  }

  /* --------------------------------------------------------------
     M05 — Magnetic card transform + 3D tilt + flood overlay
     -------------------------------------------------------------- */

  .vv-segment-card {
    /* transform-style: preserve-3d → karta jako 3D plane, dzieci
       partycypują w przestrzeni 3D (działają translateZ jeśli kiedyś
       dodamy). overflow: hidden + isolation: stacking context dla
       flood layer pseudo-element. */
    transform-style: preserve-3d;
    overflow: hidden;
    isolation: isolate;
    /* Resting baseline: zero translate, zero rotate, zero magnetic shift.
       Custom properties fallback do 0 / 0deg jeśli JS nie zdążył ustawić
       (np. pre-hydration). */
    transform: translate3d(
        var(--vv-card-tx, 0px),
        var(--vv-card-ty, 0px),
        0
      )
      rotateX(var(--vv-card-rx, 0deg)) rotateY(var(--vv-card-ry, 0deg));
    /* Return-to-rest: 400ms premium ease (cubic-bezier match z motion-tokens).
       Aktywnie podczas hover: skracane do 80ms linear przez
       [data-magnetic-active="true"] niżej (responsive cursor tracking). */
    transition:
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow var(--vv-motion-duration-base) var(--vv-motion-easing-standard),
      border-color var(--vv-motion-duration-base)
        var(--vv-motion-easing-standard);
  }

  .vv-segment-card__flood {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      260px circle at var(--vv-card-mx, 50%) var(--vv-card-my, 50%),
      color-mix(in srgb, var(--vv-card-accent, currentColor) 14%, transparent)
        0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 380ms ease;
    pointer-events: none;
    z-index: 0;
    /* GPU promotion na hover only (managed przez parent state).
       Bez tego flood layer compositing każdą klatkę = paint cost. */
  }

  /* Wszystkie children OPRÓCZ flood layer dostają z-index: 1 żeby
     renderować się NAD radial-gradient. Selector używa :not żeby
     flood layer trzymał z-index 0 i był wyłącznie tłem. */
  .vv-segment-card > *:not(.vv-segment-card__flood) {
    position: relative;
    z-index: 1;
  }

  /* Neutralizujemy default Card hover lift (translateY -2px) — magnetic
     karty mają własny transform i konflikt by powodował "skok" na
     pointerenter. Specificity .vv-segment-card.vv-card--interactive */
  .vv-segment-card.vv-card--interactive:hover,
  .vv-segment-card.vv-card--interactive:focus-visible {
    transform: translate3d(
        var(--vv-card-tx, 0px),
        var(--vv-card-ty, 0px),
        0
      )
      rotateX(var(--vv-card-rx, 0deg)) rotateY(var(--vv-card-ry, 0deg));
  }

  @media (pointer: fine) {
    .vv-segment-card:hover .vv-segment-card__flood,
    .vv-segment-card:focus-within .vv-segment-card__flood {
      opacity: 1;
    }

    /* Active magnetic state — krótkie transition żeby kursor "ciągnął"
       kartę bez delay. Po pointerleave wraca do default 400ms cubic. */
    .vv-segment-card[data-magnetic-active="true"] {
      transition: transform 80ms linear;
      will-change: transform;
    }
  }

  @media (pointer: coarse) {
    /* Touch devices: brak magnetic, jedynie subtle flood przy tap (active
       state krótki, ale lepsze niż nic). Hover na touch = sticky po tapie
       w wielu browserach, akceptowalne dla card-as-link. */
    .vv-segment-card:hover .vv-segment-card__flood,
    .vv-segment-card:active .vv-segment-card__flood {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    /* Defense in depth: JS nie binduje listenerów przy reduced-motion,
       ale gdyby coś wyciekło — CSS zeruje transform i transition.
       Flood opacity nadal działa (instant, bez transition) bo to nie
       jest motion, tylko color change. */
    .vv-segment-card {
      transform: none !important;
      transition: none !important;
      will-change: auto !important;
    }
    .vv-segment-card__flood {
      transition: none !important;
    }
  }

  .vv-segments__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--vv-space-3);
  }

  .vv-segments__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--vv-radius-md);
    background-color: color-mix(in srgb, var(--vv-seg-color) 12%, transparent);
    color: var(--vv-seg-color);
  }

  .vv-segments__title {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-xl);
    font-weight: var(--vv-typography-font-weight-bold);
    line-height: var(--vv-typography-line-height-snug);
    color: var(--vv-color-fg-primary);
    margin: 0;
  }

  .vv-segments__desc {
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    margin: 0;
    flex-grow: 1;
  }

  .vv-segments__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--vv-space-2);
    /* WCAG 1.4.3 AA: niektóre segment colors (#D97706 rodzinne 3.18:1,
       #F13223 eventy 4.42:1) failują 4.5:1 dla tekstu sm semibold na białym.
       Tekst CTA = primary fg; akcent segmentowy zostaje przez ikonę chevron
       (non-text 3:1) + left-border w Card. */
    color: var(--vv-color-fg-primary);
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-sm);
    font-weight: var(--vv-typography-font-weight-semibold);
    margin-top: auto;
    transition: gap var(--vv-motion-duration-fast)
      var(--vv-motion-easing-standard);
  }

  .vv-segments__cta :global(.vv-icon) {
    color: var(--vv-seg-color);
  }

  .vv-segments__card:hover .vv-segments__cta,
  .vv-segments__card:focus-visible .vv-segments__cta {
    gap: var(--vv-space-3);
  }
</style>
