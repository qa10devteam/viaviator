---
/**
 * FAQAccordion — natywne <details>/<summary>, brak JS.
 * Każdy item = jedno pytanie + odpowiedź. JSON-LD FAQPage do generowania
 * w page-level, nie tutaj (komponent jest agnostyczny strukturalnie).
 */

import Icon from "@components/ui/Icon.astro";

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  /** Pierwszy item domyślnie rozwinięty. */
  defaultOpenFirst?: boolean;
  class?: string;
}

const {
  items,
  defaultOpenFirst = false,
  class: extraClass = "",
} = Astro.props;
---

<ul class:list={["vv-faq", extraClass]} role="list">
  {
    items.map((item, idx) => (
      <li class="vv-faq__item">
        <details
          class="vv-faq__details"
          open={defaultOpenFirst && idx === 0}
        >
          <summary class="vv-faq__summary">
            <span class="vv-faq__q">{item.q}</span>
            <span class="vv-faq__caret" aria-hidden="true">
              <Icon name="chevron-down" size={20} />
            </span>
          </summary>
          <div class="vv-faq__answer">
            <p>{item.a}</p>
          </div>
        </details>
      </li>
    ))
  }
</ul>

<style>
  .vv-faq {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--vv-color-border-subtle);
  }

  .vv-faq__item {
    border-bottom: 1px solid var(--vv-color-border-subtle);
  }

  .vv-faq__details {
    width: 100%;
  }

  .vv-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--vv-space-4);
    padding: var(--vv-space-5) 0;
    cursor: pointer;
    list-style: none;
    color: var(--vv-color-fg-primary);
    transition: color var(--vv-motion-duration-fast)
      var(--vv-motion-easing-standard);
  }

  .vv-faq__summary::-webkit-details-marker {
    display: none;
  }

  .vv-faq__summary:hover {
    color: var(--vv-color-fg-accent);
  }

  .vv-faq__q {
    font-family: var(--vv-typography-font-family-display);
    font-size: var(--vv-typography-font-size-lg);
    font-weight: var(--vv-typography-font-weight-semibold);
    line-height: var(--vv-typography-line-height-snug);
    text-wrap: balance;
  }

  .vv-faq__caret {
    display: inline-flex;
    flex-shrink: 0;
    color: var(--vv-color-fg-secondary);
    transition: transform var(--vv-motion-duration-base)
      var(--vv-motion-easing-standard);
  }

  .vv-faq__details[open] .vv-faq__caret {
    transform: rotate(180deg);
  }

  .vv-faq__answer {
    padding: 0 0 var(--vv-space-5);
    max-width: 72ch;
  }

  .vv-faq__answer p {
    margin: 0;
    font-size: var(--vv-typography-font-size-base);
    line-height: var(--vv-typography-line-height-relaxed);
    color: var(--vv-color-fg-secondary);
    text-wrap: pretty;
  }
</style>
