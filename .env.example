# Via Viator — env. Sekrety podpinamy na końcu launchu (per QA10 doctrine).

PUBLIC_SITE_URL=https://viaviator.pl
PUBLIC_DEFAULT_LOCALE=pl

# Kontakt — telefon i mail zatwierdzone przez klienta 19.05.2026
PUBLIC_BRAND_PHONE=+48 690 691 886
PUBLIC_BRAND_EMAIL_CONTACT=kontakt@viaviator.pl
PUBLIC_BRAND_EMAIL_BOARD=zarzad@viaviator.pl
PUBLIC_BRAND_EMAIL_MARKETING=marketing@viaviator.pl
# Stary, do migracji przed go-live:
PUBLIC_BRAND_EMAIL_LEGACY=viaviator.kontakt@gmail.com

# Identyfikacja prawna (KRS i adres siedziby — do uzupełnienia przez klienta)
PUBLIC_BRAND_NIP=6452595911
PUBLIC_BRAND_KRS=
PUBLIC_BRAND_ADDRESS=

# Formularz kontaktowy → AWS SES (server-side, Vercel env)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=kontakt@viaviator.pl
SES_TO_EMAIL=kontakt@viaviator.pl

# QA10 Quality Seal — wykonawca i credit
PUBLIC_QA10_SEAL_VERSION=1.0
PUBLIC_QA10_SEAL_URL=https://qa10.io/seal/viaviator
PUBLIC_QA10_HOME=https://qa10.io

# Analytics — opt-in po consent (RODO)
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_HOST=
